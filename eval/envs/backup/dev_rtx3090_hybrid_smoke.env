# =============================================================================
# dev_rtx3090_hybrid_smoke.env — Quick CPU-hybrid validation on dev box
# i9-12900KF (16P/24L, AVX2/AVX-VNNI, no AVX-512/AMX) + RTX 3090 24GB
# =============================================================================

# --- Model (small enough that 1.5B fits comfortably) ---
MODEL=Qwen/Qwen2.5-1.5B-Instruct
PORT=8000

# --- Server common ---
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# --- Benchmark (smoke test sized — short input/output, few prompts) ---
NUM_PROMPTS=40
INPUT_LEN=128
OUTPUT_LEN=64
REQUEST_RATE=inf

# --- Hybrid settings ---
# 1 sequence first — verify a single CPU request can saturate all cores.
# If 1-seq doesn't use all cores, the bug is in OMP/affinity, NOT in batch size.
HYBRID_CPU_MAX_SEQS=1
HYBRID_CPU_KVCACHE_GB=8
HYBRID_CPU_THREADS=0          # auto = all 16 physical cores
HYBRID_NUMA_AWARE=false       # single socket
HYBRID_NUM_CPU_ENGINES=1
HYBRID_STATS_LOG_INTERVAL=10

# Force capacity (CPU-first) so every burst goes to CPU first → easy to verify
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=2048
HYBRID_WARMUP_REQUESTS=0      # disable warmup phase for the smoke test

# --- Trace knobs (consumed by code we just instrumented) ---
VLLM_HYBRID_TRACE=0           # 1 = log every CPU exec_model + every attn call
VLLM_HYBRID_TRACE_EVERY=20    # otherwise log every 20 calls

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server startup wait ---
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=5
