# =============================================================================
# h100x4_qwen32b_hybrid.env
#
# 목적: Qwen2.5-32B-Instruct 를 H100x4 + Xeon 8480+ 에서 hybrid 모드로 실험.
#       1.5B / 7B 와 같은 shape (500 req × 128/128) 으로 직접 비교 가능하게
#       구성. paper 의 1.5B → 7B → 32B scaling 분석 baseline.
#
# 모델 메모: Qwen2.5-32B-Instruct
#   - 32 B params, BF16 weight ≈ 64 GB
#   - hidden 5120, layers 64, attn heads 40, KV heads 8 (GQA 5:1)
#   - max position 32768 (본 실험은 4096 으로 제한, 짧은 shape 비교용)
#
# 메모리 배분 (TP=4, GPU_MEMORY_UTIL=0.90):
#   - per-GPU available ≈ 80 × 0.90 = 72 GB
#   - per-GPU weight ≈ 64 / 4 = 16 GB
#   - per-GPU activation + workspace ≈ 4~6 GB
#   - per-GPU KV cache ≈ 50 GB → 4-GPU total ~200 GB
#   - 1.5B/7B 와 다르게 KV 가 batch 한계의 진짜 bottleneck. ninja gap (KV
#     offload, spec decode) demo 가 의미를 갖는 첫 모델.
#
# 최적화 선택 근거 (1.5B/7B env 와 동일 정책):
#   - Routing strategy = throughput-adaptive + cpu-first
#     → expected-finish gate fix (commit 3f528123e) 가 정확한 결정을 내리도록
#       router 에 맡김. H100 + 32B 에서도 GPU per-req 가 CPU 보다 빠르므로
#       대부분 GPU. 단 batch 가 KV 한계로 잘려 GPU wait 가 길어지면 일부
#       요청이 자동으로 CPU 로 흡수될 가능성 — 1.5B/7B 보다 hybrid 효과가
#       처음으로 0% 가 아닌 양수로 측정될 수 있음.
#   - Silent stdout (TRACE=0, EVERY=0) — fast-path contention 방지.
#   - auto everything — 96 core 1:1 pin, NUMA auto, kvcache auto.
#   - warmup=10 — throughput-adaptive EMA 초기 안정화.
#   - HYBRID_CPU_PREFILL_THRESHOLD=1024 — prefill 도 CPU 후보 (in=128 시 적용 안 됨).
#
# 참고:
#   - 7B 대비 GPU step time 이 ~3~4× 길어짐. wall ~30~50s 예상 (gpu_only).
#   - CPU 32B BF16 은 ~0.3~0.5 tok/s 추정 (BW bound). request-level partition
#     으로는 본질적으로 CPU 를 못 씀 → ninja gap 은 spec decode / KV offload
#     를 별도로 구현해야 발현. 본 env 는 그 baseline 측정용.
#   - 32 B BF16 weight (64 GB) 다운로드 필요: hf download Qwen/Qwen2.5-32B-Instruct
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-32B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server (H100x4 TP=4, 32B BF16 ≈ 64 GB → per-GPU 16 GB weight)
#   max-model-len 4096: 1.5B/7B 와 동일, 짧은 shape 비교 baseline.
#   long context (32K+) 실험은 별도 env 로 분기.
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# -----------------------------------------------------------------------------
# Benchmark — 500 req burst, 표준 128/128 shape
# (1.5B/7B 와 동일. 길이 분포 실험은 ShareGPT env 로 별도 구성)
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid (모든 CPU 파라미터 auto — 설계 원칙 적용)
#   num_cpu_engines = NUMA nodes (auto → 1 on H100x4 KVM)
#   cpu_max_num_seqs = 1 per engine (원칙 고정)
#   cpu_threads = 96 (auto, 물리 코어 전체)
#   cpu_kvcache_gb = clamp(eff_mem × 0.4, 32, 512) (auto)
# -----------------------------------------------------------------------------
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=50

HYBRID_ROUTING_STRATEGY=throughput-adaptive
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=10

# -----------------------------------------------------------------------------
# Logging — serving silent (production 실험 필수)
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
#   32B 부팅 시간이 1.5B/7B 보다 훨씬 길 수 있으므로 ready timeout 여유롭게.
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=1800
SERVER_READY_POLL=5
