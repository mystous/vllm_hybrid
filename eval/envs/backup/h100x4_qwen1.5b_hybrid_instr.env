# =============================================================================
# h100x4_qwen1.5b_hybrid_instr.env
#
# 계측 전용 env — h100x4_qwen1.5b_hybrid.env 파생.
# 차이: HYBRID_STATS_LOG_INTERVAL=10 (INFO 승격된 [HYBRID-ROUTER-STATS] 10건마다)
#      + [HYBRID-CPU-EXEC] 50 스텝마다 샘플링 (CPU scheduler running 수 확인용)
# =============================================================================

MODEL=Qwen/Qwen2.5-1.5B-Instruct
PORT=8000

GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=10

HYBRID_ROUTING_STRATEGY=throughput-adaptive
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=10

# Sample CPU engine batch size every 50 steps to verify internal max_num_seqs.
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=50

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
