# =============================================================================
# dev_rtx3090.env — Development Linux machine (i9-12900KF + RTX 3090 24GB)
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-1.5B
PORT=8000

# --- Server common ---
GPU_MEMORY_UTIL=0.9
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# --- Benchmark ---
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=512
REQUEST_RATE=inf

# --- Hybrid settings ---
# i9-12900KF: 16P+8E cores, no NUMA
# auto-detect: cpu_max_seqs~4, kvcache~24GB, threads~8 (P-cores)
HYBRID_CPU_MAX_SEQS=1            # All cores on single request
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=false          # Single socket, no NUMA
HYBRID_NUM_CPU_ENGINES=1         # Single CPU engine
HYBRID_STATS_LOG_INTERVAL=10
HYBRID_ROUTING_STRATEGY=round-robin
HYBRID_ROUTING_PRIORITY=gpu-first    # ignored for round-robin    # gpu-first | cpu-first (round-robin시 무시)

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server startup wait ---
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=10
