# =============================================================================
# h100x4_qwen7b_hybrid.env
#
# 목적: Qwen2.5-7B-Instruct 를 H100x4 + Xeon 8480+ 에서 hybrid 모드로
#       **최적 속도**로 실험. GPU-only 벤치와 바로 비교 가능.
#
# (rename 이력: 직전 버전명 `h100x4_qwen7b_hybrid_smoke.env`.
#  원래 smoke 용이었으나 본 파일은 production 실험 config 로 재정의됨.)
#
# 최적화 선택의 근거:
#   - Routing strategy = **throughput-adaptive** + **cpu-first**
#     → 1.5B 실험 (085801) 에서 hybrid penalty 0 입증. 7B 는 CPU 가 더 느리지만
#        (2.3 tok/s, BW bound — Tech_done v3 F2) 적응형이 같은 방식으로 slow CPU
#        를 회피하므로 penalty 없는 gpu-only 수렴이 기대됨.
#   - **Silent stdout** (TRACE=0, EVERY=0)
#     → fast-path contention 방지. experiment_result/20260411_121509 참조.
#   - **auto everything** → 96 core 1:1 pin, NUMA auto, kvcache auto
#   - **warmup=10** → throughput-adaptive EMA 초기 안정화
#   - **`HYBRID_CPU_PREFILL_THRESHOLD=1024`** → prefill 도 CPU 후보 (in=128 시 적용 안 됨)
#
# 참고:
#   - 7B 는 GPU 자체가 느리므로 wall 이 1.5B 대비 길어짐 (duration ~30s 예상)
#   - BW bound 때문에 AMX 추가 가치는 없음. 차후 int8 quant + AMX_INT8 실험 필요.
#   - 70B scaling 실험도 BW bound 가정 반증용으로 가치 있음.
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server (H100x4 TP=4, 7B BF16 ≈ 14 GB — 4x80GB 여유, CUDA graphs 기본 활성)
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# -----------------------------------------------------------------------------
# Benchmark — 500 req burst, 표준 128/128 shape
# (길이 분포 실험 필요 시 ShareGPT env 로 별도 구성)
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid (모든 CPU 파라미터 auto — 설계 원칙 적용)
#   num_cpu_engines = NUMA nodes (auto → 1 on H100x4 KVM)
#   cpu_max_num_seqs = 1 per engine (원칙 고정)
#   cpu_threads = 96 (auto, 물리 코어 전체)
#   cpu_kvcache_gb = clamp(eff_mem × 0.4, 32, 512) (auto)
# -----------------------------------------------------------------------------
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=50        # 50 완료마다 Router stats (debug level)

HYBRID_ROUTING_STRATEGY=throughput-adaptive
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=10

# -----------------------------------------------------------------------------
# Logging — **serving silent** (production 실험 필수)
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
