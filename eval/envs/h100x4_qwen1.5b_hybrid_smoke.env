# =============================================================================
# h100x4_qwen7b_hybrid_smoke.env — 10-prompt smoke on H100x4 + Xeon 8480+
# Target: 부팅 + abort 패치 포함 상태에서 capacity stuck 증상 해소 확인.
#         AMX/AVX-512 CPU path 첫 관측 ([HYBRID-CPU-ATTN] decode counter).
# Baseline 비교: dev (i9-12900KF + RTX3090) — Tech_done v1 Q1~Q4 / v3 F1~F6
# =============================================================================

MODEL=Qwen/Qwen2.5-1.5B-Instruct
PORT=8000

# --- Server ---
# 7B BF16 ≈ 14 GB → TP=4 × 80GB 에서는 사실상 KV cache 는 무제한
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# --- Benchmark (10 prompt smoke, dev 500 req 와 동일 shape) ---
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# --- Hybrid (전부 auto — NUMA 1 node 감지 → num_cpu_engines=1) ---
# cpu_max_num_seqs=1 (auto), num_cpu_engines=1 (auto), kvcache/threads auto
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=10

HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_WARMUP_REQUESTS=0

# smoke 는 trace on — 부팅/라우팅/CPU worker pin 경로 전수 기록
VLLM_HYBRID_TRACE=1
VLLM_HYBRID_TRACE_EVERY=1

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
