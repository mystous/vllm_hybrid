# =============================================================================
# h100x1_qwen1.5b_hybrid_wave.env
#
# 목적: h100x4_qwen1.5b_hybrid_wave.env 의 single-GPU 변형.
#       1.5B + CPU matmul batching + wave-batch routing 을 H100x1 에서 측정.
#       TP=4 → TP=1 만 차이. 나머지 hybrid 세팅 모두 동일.
#
# 하드웨어: H100 80GB HBM3 × 1, Xeon Platinum 8480+ (96 vCPU, 1 NUMA),
#           944 GB DDR5. AVX-512F/VNNI/BF16, AMX-BF16/INT8.
#
# 모델 메모: Qwen2.5-1.5B-Instruct
#   - 1.5 B params, BF16 weight ≈ 3 GB (per-GPU 3 GB, TP=1 이므로 분할 없음)
#   - H100x1 GPU wall 은 H100x4 대비 ~2-4x 증가 예상 (가능 max_seqs 축소 포함)
#   - batch 처리량은 여전히 GPU underutilized 구간
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-1.5B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server — H100x1 TP=1
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# -----------------------------------------------------------------------------
# Benchmark — 500 req burst, 표준 128/128 shape (H100x4 env 와 shape 통일)
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — H100x4 env 와 동일
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=16
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=25

HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0

# -----------------------------------------------------------------------------
# Logging — serving silent
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=5
