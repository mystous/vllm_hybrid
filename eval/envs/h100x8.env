# =============================================================================
# h100x8.env — H100 SXM 80GB x8 + Xeon Platinum 8480+ Dual-Socket
#              (TP=8, 2x NUMA CPU engines)
# =============================================================================

# --- Model ---
# Use full path or HuggingFace model ID
MODEL=Qwen/Qwen2.5-72B-Instruct
PORT=8000

# --- Server common ---
GPU_MEMORY_UTIL=0.9
TENSOR_PARALLEL_SIZE=8           # 8x H100 tensor parallel
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# --- Benchmark ---
NUM_PROMPTS=2000
INPUT_LEN=512
OUTPUT_LEN=512
REQUEST_RATE=inf

# --- Hybrid settings ---
# Xeon 8480+: 2 sockets x 56 cores x 2 threads = 224 logical cores
# NUMA node 0: socket 0 (56P cores), NUMA node 1: socket 1 (56P cores)
# auto-detect per NUMA node: cpu_max_seqs~14, kvcache~400GB, threads~56
HYBRID_CPU_MAX_SEQS=0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true           # Dual-socket NUMA mandatory
HYBRID_NUM_CPU_ENGINES=2         # One CPU engine per NUMA node
HYBRID_STATS_LOG_INTERVAL=50
HYBRID_ROUTING_STRATEGY=capacity

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server startup wait ---
SERVER_READY_TIMEOUT=600         # 72B model load takes longer
SERVER_READY_POLL=10
