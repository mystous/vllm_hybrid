# =============================================================================
# ide006_cold_kv_split_on.env — IDE_006 second-cut with the *full* feature
#   activated: OffloadingConnector + Cold-KV CPU partial attention path
#   (enable_cpu_partial_attention=True). The first env in the eval set that
#   actually exercises the TSK_002 §4 dispatcher introduced in Phase 4c.
#
# Compared to ide006_cold_kv.env:
#   + adds enable_cpu_partial_attention=True so model_runner routes the cold
#     prefix through TSK_001's CPU partial-attention kernel and merges via
#     merge_attn_states.
#   - everything else (model, prompt sweep, monitoring) is identical.
#
# Behaviour notes:
#   * On dev (RTX 3090 24 GB) with this short prompt sweep (in=512, out=256,
#     200 prompts) the GPU KV cache rarely fills enough to evict blocks, so
#     the dispatcher's hot/cold split branch may seldom take the cold path.
#     For long-context stress see ide006_cold_kv_long_ctx_split_on.env once it
#     lands; for prod (Xeon SPR + H100 x8) the long-context env triggers
#     real offloading.
#   * Default-off comparison baseline stays vllm_original.env. For a paired
#     "OffloadingConnector but no CPU partial attention" baseline use
#     ide006_cold_kv.env.
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=4096

# IDE_006 (a) cold-tier KV offload + (b) CPU partial-attention activation.
# `enable_cpu_partial_attention` is a top-level KVTransferConfig field; placed
# alongside kv_connector / kv_role rather than inside kv_connector_extra_config.
# Note: omitting `block_size` from kv_connector_extra_config keeps the
# offloaded block size aligned with the GPU block size (block_size_factor==1),
# which is currently the only configuration supported by the Cold-KV CPU
# partial attention path — TSK_002 Phase 4 scope-locks that case.
EXTRA_SERVE_ARGS='--kv-transfer-config={"kv_connector":"OffloadingConnector","kv_role":"kv_both","enable_cpu_partial_attention":true,"kv_connector_extra_config":{"cpu_bytes_to_use":1073741824}}'

# --- Benchmark (matches vllm_original.env / ide006_cold_kv.env) ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=200
INPUT_LEN=512
OUTPUT_LEN=256
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
SERVER_READY_TIMEOUT=300
SERVER_READY_POLL=3
