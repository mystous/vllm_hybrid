# =============================================================================
# h100x1_qwen32b_hybrid_wave.env
#
# 목적: h100x4_qwen32b_hybrid_wave.env 의 single-GPU 변형.
#       32B 를 H100x1 80GB 1장에 올리는 tight configuration.
#
# 하드웨어: H100 80GB HBM3 × 1, Xeon Platinum 8480+ (96 vCPU, 1 NUMA),
#           944 GB DDR5.
#
# 모델 메모: Qwen2.5-32B-Instruct
#   - 32 B params, BF16 weight ≈ 64 GB (단일 GPU 에 전부 로드)
#   - 80 GB × 0.90 = 72 GB available → weight 64 GB + KV/activation 8 GB
#   - KV cache 가 TP=4 (~50 GB) 대비 극도로 타이트 → batch size 축소 필수
#   - 부팅 시간 길어서 READY_TIMEOUT 여유있게.
#
# 주의사항:
#   - KV cache 8 GB 로는 continuous batching 의 GPU max_num_seqs 가 수십 정도로
#     떨어질 가능성. OOM 나면 GPU_MEMORY_UTIL 을 0.92-0.95 까지 올려보거나
#     max-model-len 을 2048 로 축소 고려.
#   - TP=4 baseline (wall 7s) 대비 per-step 시간이 compute + memory-BW 압력
#     둘 다로 ~5-10x 증가 예상. wall 약 40-70s 예상.
#   - 따라서 이 env 는 CPU 32B decode 의 상대적 비율이 처음으로 의미 있는
#     영역을 만드는 dev 후보 workload 가 됨 (H100x4 에서는 sub-saturated).
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-32B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server — H100x1 TP=1
#   max-model-len 4096 유지 (H100x4 와 shape 통일 목적).
#   KV cache 압력이 오히려 hybrid 효과를 드러낼 가능성 — 이게 본 env 의 가치.
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.92
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# -----------------------------------------------------------------------------
# Benchmark — 500 req burst, 표준 128/128 shape
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — H100x4 env 와 동일
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=16
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=25

HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0

# -----------------------------------------------------------------------------
# Logging — serving silent
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
#   32B + TP=1 부팅: weight 64GB 로드 + KV 공간 할당 + warmup → 200s+ 예상.
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=1800
SERVER_READY_POLL=5
