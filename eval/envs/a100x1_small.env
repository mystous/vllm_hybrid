# =============================================================================
# a100x1_small.env — A100 SXM 80GB x1, Xeon Gold 6338 1S/16C (KVM)
# Small model (1.5B) for CPU-constrained environments
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-1.5B-Instruct
PORT=8000

# --- Server common ---
GPU_MEMORY_UTIL=0.9
TENSOR_PARALLEL_SIZE=1

# --- Benchmark ---
NUM_PROMPTS=500
INPUT_LEN=256
OUTPUT_LEN=256
REQUEST_RATE=inf

# --- Hybrid settings ---
# Xeon Gold 6338: 1 socket, 16 cores, no HT, AVX-512 + VNNI, no AMX
# KVM VM, 188GB RAM (available ~92GB)
# 1.5B model is ~4x lighter — CPU can handle more concurrent seqs
HYBRID_CPU_MAX_SEQS=4            # 1.5B is light enough for 4 concurrent seqs on 16C
HYBRID_CPU_KVCACHE_GB=32         # Conservative — leave headroom for OS + GPU host mem
HYBRID_CPU_THREADS=12            # Reserve 4 cores for OS/GPU host threads
HYBRID_CPU_MAX_BATCHED_TOKENS=2048  # 4 seqs × 512 tokens
HYBRID_NUMA_AWARE=false          # Single socket — no NUMA optimization needed
HYBRID_NUM_CPU_ENGINES=1         # Single CPU engine
HYBRID_STATS_LOG_INTERVAL=50
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=gpu-first    # gpu-first | cpu-first (round-robin시 무시)

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server startup wait ---
SERVER_READY_TIMEOUT=300
SERVER_READY_POLL=5
