# =============================================================================
# h100x4_qwen32b_hybrid_wave.env
#
# 목적: 32B 에서 CPU matmul batching (cpu_max_num_seqs > 1) + wave-batch
#       routing 의 효과 측정. 1.5B/7B/32B baseline (h100x4_qwen32b_hybrid.env)
#       과 직접 비교 가능한 같은 shape (500 req × 128/128).
#
# 핵심 차이:
#   - cpu_max_num_seqs = 16 (1 → 16, batched matmul 활성화)
#     → 한 forward pass 가 M-dim=16 으로 수행되어 weight DRAM 로드를
#       16 req 가 공유, 이론상 CPU throughput 최대 16× 증가
#   - routing_strategy = wave-batch
#     → CPU 에 16 req 묶음을 admit 하고 전부 완료된 후 다음 wave 를 연다
#       (partial wave 무시). GPU 는 계속 request 를 받는다.
#   - cpu_core_ratio = 1.0 (NUMA 전체 코어 사용; 필요 시 0.9 등으로 축소
#     실험 가능 — activation cache footprint 가 L3 를 넘치는지 관찰용)
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-32B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# -----------------------------------------------------------------------------
# Benchmark — 500 req burst, 표준 128/128 shape
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — CPU batching 활성화
#   HYBRID_CPU_MAX_SEQS=16  → per-engine forward pass batch M-dim
#   HYBRID_CPU_CORE_RATIO=1.0 → NUMA 모든 물리 코어 사용 (0.9 로 축소 가능)
#   HYBRID_NUM_CPU_ENGINES=0 → auto (NUMA 노드 수)
#   HYBRID_ROUTING_STRATEGY=wave-batch
#
#   총 동시 CPU req = cpu_max_num_seqs × num_cpu_engines
#                    = 16 × 1 (H100x4 KVM 1-NUMA) = 16
#                    = 16 × 2 (H100x8 2-socket) = 32
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=16
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=25

HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0

# -----------------------------------------------------------------------------
# Logging — serving silent
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=1800
SERVER_READY_POLL=5
