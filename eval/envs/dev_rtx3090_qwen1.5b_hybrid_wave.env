# =============================================================================
# dev_rtx3090_qwen1.5b_hybrid_wave.env
#
# 목적: h100x4_qwen32b_hybrid_wave.env 와 동일 구조를 현재 dev 머신에서
#       재현. CPU matmul batching (cpu_max_num_seqs > 1) + wave-batch
#       routing 의 효과를 작은 모델 + 작은 GPU 에서 먼저 검증.
#
# 머신: i9-12900KF (16 physical cores = 8P + 8E, AVX2 + AVX-VNNI, AMX ❌)
#       + RTX 3090 24 GB + 62 GB RAM, 1 NUMA node
#
# 주의: dev 는 AVX-512/AMX 없어서 CPU 경로가 IPEX oneDNN AVX2 fallback 으로
#       돌고, 실측 CPU 7B = 2.3 tok/s 수준. 1.5B 도 CPU 에선 ~10 tok/s 정도.
#       wave-batch + batching 으로 CPU throughput 이 얼마나 개선되는지
#       확인하는 것이 이 env 의 주 목적.
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-1.5B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server — RTX 3090 24 GB
#   1.5B BF16 ≈ 3 GB weight, 나머지 KV cache 에 충분한 여유.
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# -----------------------------------------------------------------------------
# Benchmark — H100 env 와 같은 shape (500 req × 128/128)
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — CPU batching 활성화
#   HYBRID_CPU_MAX_SEQS=16  → per-engine forward pass batch M-dim
#   HYBRID_CPU_CORE_RATIO=1.0 → 16 physical core 전부 사용
#   HYBRID_NUM_CPU_ENGINES=0 → auto (dev 1-NUMA → 1 engine)
#   HYBRID_ROUTING_STRATEGY=wave-batch
#
#   총 동시 CPU req = cpu_max_num_seqs × num_cpu_engines = 16 × 1 = 16
#
#   CPU KV cache: 1.5B 는 충분히 작아 8 GB 면 여유.
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=16
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=8
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=25

HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0

# -----------------------------------------------------------------------------
# Logging — serving silent
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=5
