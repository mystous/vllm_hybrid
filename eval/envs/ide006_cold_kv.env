# =============================================================================
# ide006_cold_kv.env — IDE_006 (Cold-KV CPU Partial Attention), enabling only
#   the parts of the second-cut definition that already have a toggle in code.
#
# IDE_006 second-cut = (a) cold-tier KV offload + (b) CPU partial-attention
#   worker + (c) LSE-returning CPU kernel + (d) merge_attn_states sum.
#   (b) and (c) are not yet implemented, so this env enables only (a).
#   See: shadow_assists/features/IDE_006/README.md
#
# What is enabled:
#   - vLLM built-in OffloadingConnector (no external dependency; uses the
#     default CPUOffloadingSpec).
#   - cpu_bytes_to_use: 1 GiB (conservative starting point for the
#     RTX 3090 + 128/128 workload; raise it when switching to long-context).
#   - block_size: 64 (standard example from vLLM docs).
#
# Comparison baseline: vllm_original.env (all options off, GPU-only).
# Hardware reference: RTX 3090 + Qwen2.5-7B-Instruct.
# Reference patterns: docs/features/disagg_prefill.md:44,
#                     tests/v1/kv_offload/test_cpu_offloading.py:197
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
# OffloadingConnector keeps an extra KV buffer in CPU DRAM, so leave a slightly
# wider margin on the GPU side.
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=4096

# IDE_006 (a): cold-tier KV offload via OffloadingConnector.
# Wrap the JSON in single quotes with no whitespace (safe under env-file source).
EXTRA_SERVE_ARGS='--kv-transfer-config={"kv_connector":"OffloadingConnector","kv_role":"kv_both","kv_connector_extra_config":{"cpu_bytes_to_use":1073741824,"block_size":64}}'

# --- Benchmark (matches vllm_original.env) ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=200
INPUT_LEN=512
OUTPUT_LEN=256
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
SERVER_READY_TIMEOUT=300
SERVER_READY_POLL=3
