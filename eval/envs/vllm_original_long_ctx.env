# =============================================================================
# vllm_original_long_ctx.env — long-context split-off baseline.
#   본 env 는 cold-tier KV offload / CPU partial attention 모두 비활성.
#   long-context (≥ 8K) workload 의 vanilla GPU-only 결과를 측정해
#   `ide006_cold_kv_long_ctx.env` 의 baseline 으로 사용한다.
#
# 시나리오:
#   - INPUT_LEN=8192  (long-context, IDE_006 §10 의 (a) 시뮬레이션 영역)
#   - OUTPUT_LEN=128  (decode 짧게 — split 의 효과는 prefill 측에)
#   - NUM_PROMPTS=10  ("적은 req" — kv-cache pressure 가 충분히 발생하나
#                       benchmark 시간은 합리적)
#   - MAX_MODEL_LEN=16384 (8K input + 128 output 여유 + headroom)
#
# 비교 짝: ide006_cold_kv_long_ctx.env (동일 sweep + OffloadingConnector).
# 하드웨어 기준: RTX 3090 (24 GB) + Qwen2.5-7B-Instruct.
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
GPU_MEMORY_UTIL=0.9
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=16384
EXTRA_SERVE_ARGS=""

# --- Benchmark ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=10
INPUT_LEN=8192
OUTPUT_LEN=128
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
# Long-context 모델은 CUDA graph capture 시간이 김 — readiness 여유 추가.
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=3
