# =============================================================================
# ide006_cold_tier_only_value_64k.env — TSK_011 / TSK_012 가치 영역 측정용
#   baseline (cold-tier ON, IDE_006 OFF, ≥64K context).
#
# Llama-3.3-70B + TP=8 + 20 prompts × 65536 input × 8 output 으로 KV pool
# (worker per ~46 GiB) 를 명백히 초과하는 영역. baseline 의 vLLM native
# reload-fallback 이 한계 도달하는지 측정 — IDE_006 의 진정한 가치 영역.
# =============================================================================

MODEL=meta-llama/Llama-3.3-70B-Instruct
PORT=8000
HOST=127.0.0.1

GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=8
MAX_MODEL_LEN=65536

# cold-tier ON, IDE_006 OFF — vLLM native reload-fallback 만 동작.
EXTRA_SERVE_ARGS='--kv-transfer-config={"kv_connector":"OffloadingConnector","kv_role":"kv_both","enable_cpu_partial_attention":false,"kv_connector_extra_config":{"cpu_bytes_to_use":549755813888}}'

BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=20
INPUT_LEN=65536
OUTPUT_LEN=8
REQUEST_RATE=inf

MONITOR_INTERVAL=1
RESULTS_DIR=results

SERVER_READY_TIMEOUT=1200
SERVER_READY_POLL=5
