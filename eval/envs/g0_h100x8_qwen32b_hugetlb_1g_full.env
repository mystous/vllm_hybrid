# =============================================================================
# G0 측정 — H100x8 · Qwen2.5-32B · §03 Phase 2 (1GB hugetlb, KV cache + weights)
# =============================================================================
#
# Commit 2 기능 검증용. KV cache + 모델 weight 를 모두 1GB hugetlbfs slab 으로
# 복사. bind_params_to_hugetlb() 가 post-IPEX 시점에서 nn.Parameter 전수 복사.
#
# 호스트 전제 (sudo, 1회 준비) — weight 까지 담으려면 용량 크게 확보:
#   echo 128 > /sys/kernel/mm/hugepages/hugepages-1048576kB/nr_hugepages
#   mkdir -p /mnt/hugetlb_1g
#   mount -t hugetlbfs -o pagesize=1G,size=128G none /mnt/hugetlb_1g
#   grep HugePages_1048576 /proc/meminfo
#
# Qwen2.5-32B 는 BF16 weight ~64GB + CPU KV cache (기본 32~64GB) + slab 낭비 여유
# → 128GB 권장. 단편화 단일 블록 128GB 확보 실패 시 nr_hugepages 를 줄이거나
# 1차 실험은 KV 전용 env (hugetlb_1g_kv) 로 축소.
#
# 비교 대상:
#   - g0_00_32b/seqs1/                    (기본, 2MB THP)
#   - g0_03_hugetlb1g_kv_32b/seqs1/       (Commit 1, KV 만)
#   - g0_03_hugetlb1g_full_32b/seqs1/     (본 env, KV + weight)
#
# 저장 위치: measurement_results/H100x8/g0_03_hugetlb1g_full_32b/seqs${HYBRID_CPU_MAX_SEQS}/
#
# 효과 미비 시 (vs Commit 1): Commit 2 만 `git revert` 로 제거. Commit 1 은 유지.
# =============================================================================

HYBRID_TODO_NN=03_hugetlb1g_full_32b
HYBRID_CPU_MAX_SEQS=1

# -----------------------------------------------------------------------------
# 모델 / 워크로드
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-32B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS=""

NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — 2 NUMA engine
# -----------------------------------------------------------------------------
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

# -----------------------------------------------------------------------------
# 측정 infra
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100

# -----------------------------------------------------------------------------
# §03 Phase 2 — 1GB hugetlb (KV cache + weights)
# -----------------------------------------------------------------------------
HYBRID_HUGETLB_1G_ENABLE=1
HYBRID_HUGETLB_1G_PATH=/mnt/hugetlb_1g
HYBRID_HUGETLB_1G_BIND_WEIGHTS=1

# -----------------------------------------------------------------------------
# Ninja Gap Feature Flag
# -----------------------------------------------------------------------------
HYBRID_HUGEPAGES=1
HYBRID_WOQ_INT8=0                  # §04 기각
HYBRID_KMP_BLOCKTIME=auto

HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0

HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0

HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0

HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

# -----------------------------------------------------------------------------
# Monitor / 결과
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
