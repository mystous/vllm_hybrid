# =============================================================================
# a100x1.env — A100 SXM 80GB x1, single GPU
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

# --- Server common ---
GPU_MEMORY_UTIL=0.9
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# --- Benchmark ---
NUM_PROMPTS=2000
INPUT_LEN=512
OUTPUT_LEN=512
REQUEST_RATE=inf

# --- Hybrid settings ---
# A100 + host CPU (adjust based on actual server CPU)
# auto-detect will read actual hardware topology
HYBRID_CPU_MAX_SEQS=0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true           # Set false if single-socket host
HYBRID_NUM_CPU_ENGINES=1         # Single CPU engine
HYBRID_STATS_LOG_INTERVAL=50
HYBRID_ROUTING_STRATEGY=capacity

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server startup wait ---
SERVER_READY_TIMEOUT=300
SERVER_READY_POLL=5
