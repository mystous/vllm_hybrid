# =============================================================================
# dev_test_log_capture.env — serve/bench 로그 캡처 테스트용
# 짧은 벤치 (50 req) 로 boot.log / run.log 생성 동작만 검증
# =============================================================================

MODEL=Qwen/Qwen2.5-1.5B-Instruct
PORT=8000

GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 2048"

# 짧게 — 50 req 만
NUM_PROMPTS=50
INPUT_LEN=64
OUTPUT_LEN=32
REQUEST_RATE=inf

# Hybrid — max_seqs=1 + 1 engine (dev 는 1 NUMA)
HYBRID_NUM_CPU_ENGINES=1
HYBRID_NUMA_AWARE=true
HYBRID_CPU_MAX_SEQS=1
HYBRID_CPU_THREADS=8
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0

HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=10

# Profile ON — boot/run log 에 실제로 profile markers 가 들어오는지 확인
VLLM_HYBRID_PROFILE=1
VLLM_HYBRID_PROFILE_EVERY=5
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=300
SERVER_READY_POLL=5
