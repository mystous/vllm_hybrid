# =============================================================================
# ide006_cold_kv_split_on_value_64k.env — TSK_011 / TSK_012 가치 영역 측정용
#   split_on (cold-tier ON, IDE_006 ON, ≥64K context).
#
# 위 ide006_cold_tier_only_value_64k.env 와 모든 워크로드 동일,
# enable_cpu_partial_attention=true 차이만.
# =============================================================================

MODEL=meta-llama/Llama-3.3-70B-Instruct
PORT=8000
HOST=127.0.0.1

GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=8
MAX_MODEL_LEN=65536

# cold-tier ON, IDE_006 ON.
EXTRA_SERVE_ARGS='--kv-transfer-config={"kv_connector":"OffloadingConnector","kv_role":"kv_both","enable_cpu_partial_attention":true,"kv_connector_extra_config":{"cpu_bytes_to_use":549755813888}}'

BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=20
INPUT_LEN=65536
OUTPUT_LEN=8
REQUEST_RATE=inf

MONITOR_INTERVAL=1
RESULTS_DIR=results

SERVER_READY_TIMEOUT=1200
SERVER_READY_POLL=5
