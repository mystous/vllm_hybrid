# =============================================================================
# G0 §11 Phase 1 Batch-aware Decode Attention — H100x8 (Xeon 8480+ 2S SPR, Qwen2.5-32B)
# =============================================================================
#
# §11 Phase 1 (2026-04-20, branch `ninja-gap/11-batch-aware-decode-attn`):
#   - CPU decode attention 을 IPEX single_query_cached_kv_attention 대신
#     _PagedAttention.forward_decode (→ AVX-512 batch16_paged_attention_v1)
#     경로로 강제 라우팅.
#   - 활성 경로: env HYBRID_BATCH_AWARE_ATTN=1 → serve.sh → --hybrid-batch-aware-attn
#     → HybridConfig.batch_aware_attn=True → CPUWorker.__init__ 에서
#     set_batch_aware_attn_enabled(True) 호출 (get_kv_cache_shape 이전).
#   - KV cache layout 이 IPEX 와 다르므로 allocation/write/decode 모두
#     _PagedAttention layout 으로 통일. prefill 도 IPEX flash_attn 대신
#     pure SDPA 로 route.
#   - C++ 변경 없음 (기존 batch16_paged_attention_v1 사용), Python 변경만.
#
# 스택 구성: §06-1 v1 (Q8_0 + M-aware MLP kernel) + §11 batch-aware attn.
# 따라서 HYBRID_VNNI_HOT_PATH=1 도 함께 유지.
#
# 사전 확인 (한 줄):
#   python -c "import torch, vllm._C_cpu_ops; \
#     print('batch16=', hasattr(torch.ops._C_cpu_ops, 'batch16_paged_attention_v1'))"
#   → True 이면 재빌드 불필요. False 면
#     `pip install -e . --config-settings="cmake.args=-DVLLM_TARGET_DEVICE=cuda"`
#
# 저장 위치: measurement_results/H100x8/g0_11_qwen2.5_32b/seqs${HYBRID_CPU_MAX_SEQS}/
# 비교 기준:
#   - 1차 (Phase 1 의미 판정): §11 on (본 env) vs §06-1 v1 (g0_06_1_qwen2.5_32b_v1)
#   - 2차 (baseline 대비): §11 on vs base (g0_00_qwen2.5_32b_base)
# =============================================================================

# -----------------------------------------------------------------------------
# 측정 라운드 식별
# -----------------------------------------------------------------------------
HYBRID_TODO_NN=11
HYBRID_CPU_MAX_SEQS=64

# -----------------------------------------------------------------------------
# 모델 / 워크로드 — baseline 동일
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-32B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS=""

NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — baseline 동일
# -----------------------------------------------------------------------------
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

# -----------------------------------------------------------------------------
# 측정 infra
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=1
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100
VLLM_HYBRID_KERNEL_TRACE=0

# -----------------------------------------------------------------------------
# Ninja Gap Feature Flag — §06 + §06-1 (v1) stack 유지 + §11 ON
# -----------------------------------------------------------------------------
# Tier 0
HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto

# Tier 1 — hot path
HYBRID_VNNI_HOT_PATH=1       # §06 + §06-1 v1 stack (kernel 은 branch 에 이미 반영)
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0

# Tier 2 — batch scaling
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=1    # ← §11 Phase 1 활성 (IPEX → batch16_paged_attention_v1)
HYBRID_PERSISTENT_OMP=0

# Tier 2 — big wins
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0

# Tier 3 / 병행 / 장거리
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

# -----------------------------------------------------------------------------
# Monitor / 결과
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=5
