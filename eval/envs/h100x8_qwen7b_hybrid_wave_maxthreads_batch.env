# =============================================================================
# h100x8_qwen7b_hybrid_wave_maxthreads.env
#
# h100x8_qwen7b_hybrid_wave.env 의 variant — NUMA 당 물리 코어 전부 사용.
#
# 하드웨어: 2S × 56C × 2T = 224 logical, 2 NUMA, L3 210MB, DDR5 2x
#
# 2026-04-14 목적: CPU 를 NUMA 당 최대 thread 로 돌렸을 때 성능/문제점 관찰.
#   base env 는 profile peak (32 threads) 사용. 이 env 는 56 threads = NUMA
#   내 물리 코어 전부 사용.
#
#   Profile 상 비교점 (1.5B, Section C.5):
#     threads=32 → 23.55 tps ⭐ peak
#     threads=48 → 23.30 tps (≈flat, BW 포화)
#     threads=56 → 데이터 없음 (48 과 76 사이, 단 76 은 NUMA 경계 넘어 무의미)
#
#   예상 리스크:
#   1. TP=4 GPU worker / NCCL launcher / API server / scheduler 와의 core
#      contention. 2 engines × 56 threads = 112 cores = 전체 physical 코어
#      100% 점유. 시스템 thread 가 HT (logical 112~223) 로 밀림.
#   2. OMP barrier overhead 증가 (thread 수에 따라 barrier sync cost 선형↑).
#   3. LLC (L3 210MB/NUMA) 에서 working set 경쟁. 7B weight 14GB 는 어차피
#      DRAM 이므로 영향 미미.
#
#   기대 관찰:
#   - profile peak 32 vs max 56 의 실제 throughput 차이 (BW-bound 면
#     ≈0%, compute-bound residual 있으면 +α%)
#   - GPU throughput 이 core contention 으로 떨어지는지
#   - CPU util 이 100% 에 도달하는지, 아니면 barrier stall 로 낮아지는지
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server — TP=4
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 1024"

# -----------------------------------------------------------------------------
# Benchmark — base env 와 동일 shape
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# CPU engine 구조 (2 NUMA)
# -----------------------------------------------------------------------------
HYBRID_NUM_CPU_ENGINES=2
HYBRID_NUMA_AWARE=true

# -----------------------------------------------------------------------------
# Per-engine 설정 — NUMA 당 물리 코어 전체 (56 threads)
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=16           # solo decode (IPEX FD batch>1 회피)
HYBRID_CPU_THREADS=56           # ⚠ NUMA 내 물리 코어 전부
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0

# -----------------------------------------------------------------------------
# 라우팅 — CPU throughput 측정 목적
# -----------------------------------------------------------------------------
HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=25

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=1200
SERVER_READY_POLL=5
