# =============================================================================
# G0 §06 Hot Path Wiring (Q8_0 dispatch) — H100x8 (Xeon 8480+ 2S SPR, Qwen2.5-32B)
# =============================================================================
#
# §06 Phase A (2026-04-19, branch `ninja-gap/06-hot-path-wiring`):
#   - gate_up_proj + down_proj 의 quant_method 를 torch.ops._C_cpu_ops.q8_0_linear
#     dispatcher 로 교체 (load_model 끝에서 patch_mlp_to_q8_0 호출)
#   - 활성 경로: env HYBRID_VNNI_HOT_PATH=1 → serve.sh → --hybrid-vnni-hot-path
#     → HybridConfig.vnni_hot_path=True (기존 hybrid-* 옵션들과 동일 패턴)
#   - guard: vnni_hot_path + HAS_CPU_OPS + q8_0 op registered + arch
#     ∈ {Qwen2ForCausalLM} + LoRA off
#
# 사전 확인 (한 줄):
#   python -c "import torch, vllm._C_cpu_ops; \
#     print('q8_0_linear=', hasattr(torch.ops._C_cpu_ops, 'q8_0_linear'), \
#           'q8_0_quantize_weight=', hasattr(torch.ops._C_cpu_ops, 'q8_0_quantize_weight'))"
#   → 둘 다 True 이면 재빌드 불필요. False 면 `pip install -e . --config-settings="cmake.args=-DVLLM_TARGET_DEVICE=cuda"`
#
# 저장 위치: measurement_results/H100x8/g0_06/seqs${HYBRID_CPU_MAX_SEQS}/
# 사용법 (sweep 1→4→16):
#   cp eval/envs/g0_h100x8_qwen32b_06.env /tmp/run.env
#   for s in 1 4 16; do
#     HYBRID_CPU_MAX_SEQS=$s ./eval/serve.sh hybrid /tmp/run.env &
#     wait-ready && ./eval/bench.sh hybrid /tmp/run.env
#     mv eval/results/<ts>_* measurement_results/H100x8/g0_06/seqs$s/
#   done
# =============================================================================

# -----------------------------------------------------------------------------
# 측정 라운드 식별
# -----------------------------------------------------------------------------
HYBRID_TODO_NN=06
HYBRID_CPU_MAX_SEQS=8

# -----------------------------------------------------------------------------
# 모델 / 워크로드 — baseline (g0_h100x8_qwen32b.env) 과 완전 동일
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-32B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS=""

NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — baseline 동일
# -----------------------------------------------------------------------------
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

# -----------------------------------------------------------------------------
# 측정 infra
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100

# §06 per-call kernel trace — 500 prompts × 수천 decode 에서 로그 폭발.
# 성공 판정 / 회귀 디버깅 시에만 1 로 올리고 요청 수 줄여서 사용.
VLLM_HYBRID_KERNEL_TRACE=0

# -----------------------------------------------------------------------------
# Ninja Gap Feature Flag — §06 만 ON, 나머지 baseline 과 동일
# -----------------------------------------------------------------------------
# Tier 0
HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0            # §04 기각 (2026-04-19, §23 편입)
HYBRID_KMP_BLOCKTIME=auto

# Tier 1 — hot path
HYBRID_VNNI_HOT_PATH=1       # ← §06 Phase A 활성 (Q8_0 dispatch on gate_up/down)
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0

# Tier 2 — batch scaling
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0

# Tier 2 — big wins
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0

# Tier 3 / 병행 / 장거리
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

# -----------------------------------------------------------------------------
# Monitor / 결과
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=5
