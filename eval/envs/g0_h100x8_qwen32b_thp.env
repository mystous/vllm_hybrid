# =============================================================================
# G0 측정 — H100x8 · Qwen2.5-32B · §03 THP (2MB Transparent Huge Pages)
# =============================================================================
#
# 전제: 호스트에서 아래 명령을 먼저 실행해 THP=always 상태여야 한다.
#   sudo setup/setup_thp_rhel.sh enable
#   setup/setup_thp_rhel.sh verify
#
# env 자체는 기존 32B baseline 과 동일. THP 는 호스트 커널 옵션이라
# 런타임 flag 없음. 결과만 g0_03_thp_32b/ 폴더로 분리 수집한다.
#
# 비교 대상: measurement_results/H100x8/g0_00_32b/seqs1/  (THP=madvise 시절)
#
# 저장 위치: measurement_results/H100x8/g0_03_thp_32b/seqs${HYBRID_CPU_MAX_SEQS}/
# =============================================================================

# -----------------------------------------------------------------------------
# 측정 라운드 식별
# -----------------------------------------------------------------------------
HYBRID_TODO_NN=03_thp_32b
HYBRID_CPU_MAX_SEQS=1

# -----------------------------------------------------------------------------
# 모델 / 워크로드
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-32B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS=""

NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — 2 NUMA engine (H100x8 서버)
# -----------------------------------------------------------------------------
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=0
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

# -----------------------------------------------------------------------------
# 측정 infra
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=1
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100

# -----------------------------------------------------------------------------
# Ninja Gap Feature Flag
# -----------------------------------------------------------------------------
# §03: THP 는 런타임 flag 가 없다. 호스트 kernel 설정만 바꾼 상태.
# HYBRID_HUGEPAGES 는 문서용 marker (1=THP 켠 상태에서 측정 중)
HYBRID_HUGEPAGES=1
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto

HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0

HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0

HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0

HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

# -----------------------------------------------------------------------------
# Monitor / 결과
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=5
