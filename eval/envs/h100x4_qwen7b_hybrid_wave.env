# =============================================================================
# h100x4_qwen7b_hybrid_wave.env
#
# 목적: 7B + CPU matmul batching + wave-batch routing 을 H100x4 에서 측정.
#       1.5B/32B 와 shape 통일 (500 × 128/128). scaling 곡선 중간점.
#
# 하드웨어: H100 80GB HBM3 × 4 (TP=4), Xeon Platinum 8480+ (96 vCPU, 1 NUMA),
#           944 GB DDR5. AMX-BF16 brgemm dispatch 실측 확인 (Tech_done v4-F4).
#
# 모델 메모: Qwen2.5-7B-Instruct
#   - 7 B params, BF16 weight ≈ 14 GB → per-GPU 3.5 GB (TP=4)
#   - H100x4 에서 GPU-only wall ~4s (Tech_done v4-F3)
#   - GPU 19% util, 여전히 sub-saturated
#   - 1.5B 와 마찬가지로 GPU 가 여유 있는 구간이라 wave-batch 효과 제한적
#     이지만, CPU 경로 dispatch 확인 + scaling 중간점 기록용
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# -----------------------------------------------------------------------------
# Benchmark — 500 req burst, 표준 128/128 shape
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — 1.5B / 32B env 와 동일 세팅
# -----------------------------------------------------------------------------
# CPU engine 구조 (H100x4 KVM: 96 vCPU, 1 NUMA)
# KVM 은 2 socket 이 1 NUMA 로 보여 num_cpu_engines=1 로 resolve 됨
HYBRID_NUM_CPU_ENGINES=1
HYBRID_NUMA_AWARE=true

# Per-engine: batch=1 solo + 32 threads (profile 최적)
HYBRID_CPU_MAX_SEQS=1           # solo decode (IPEX FD batch>1 병목 회피)
HYBRID_CPU_THREADS=32           # profile 최적 (48도 가능)
HYBRID_CPU_CORE_RATIO=1.0       # threads 명시 시 무효
HYBRID_CPU_KVCACHE_GB=0
HYBRID_STATS_LOG_INTERVAL=25

HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0

# -----------------------------------------------------------------------------
# Logging — serving silent
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=1200
SERVER_READY_POLL=5
