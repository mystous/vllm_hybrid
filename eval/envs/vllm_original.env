# =============================================================================
# vllm_original.env — 본 포크의 추가 옵션을 모두 끈 vanilla baseline.
#   eval 의 default env. cold-tier KV offload / LMCache / 특정 CPU 가속 toggle
#   을 일체 켜지 않는다. GPU-only 동작 기준.
#   비교 기준 (IDE_006 등 옵션-on env 와의 baseline) 으로 사용.
#   하드웨어 기준: RTX 3090 + Qwen2.5-7B-Instruct.
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
GPU_MEMORY_UTIL=0.9
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=4096
# Extra args passed directly to `vllm serve`
EXTRA_SERVE_ARGS=""

# --- Benchmark ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=200
INPUT_LEN=512
OUTPUT_LEN=256
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1   # seconds between samples

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
SERVER_READY_TIMEOUT=300
SERVER_READY_POLL=3
