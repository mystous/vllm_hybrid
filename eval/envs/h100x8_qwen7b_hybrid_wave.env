# =============================================================================
# h100x8_qwen7b_hybrid_wave.env
#
# H100x8 물리 (2S × 56C, 2 NUMA, 224 logical)
# Qwen2.5-7B-Instruct, TP=4, wave-batch cpu_max_seqs=16
# =============================================================================

MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

HYBRID_CPU_MAX_SEQS=16
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=25

HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0

VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=1200
SERVER_READY_POLL=5
