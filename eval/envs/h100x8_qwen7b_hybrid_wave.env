# =============================================================================
# h100x8_qwen7b_hybrid_wave.env
#
# H100x8 물리 (2S × 56C × 2T = 224 logical, 2 NUMA, L3 210MB, DDR5 2x)
# Qwen2.5-7B-Instruct, TP=4 (8 GPU 중 4개 사용), wave-batch
#
# 2026-04-14 목적: 현재 구현 상태에서 CPU 가 낼 수 있는 최고 성능을 뽑는
#   구성 탐색. 컴파일러/커널/SIMD 레벨 최적화 아님.
#
#   H100x8 CPU profile (Section C.5 vLLM thread sweep, 1.5B solo decode):
#     threads= 8  → 13.77 tps
#     threads=16  → 18.92 tps
#     threads=24  → 22.16 tps
#     threads=32  → 23.55 tps  ⭐ peak (NUMA 0 내부)
#     threads=48  → 23.30 tps  (BW 포화, diminishing)
#     threads=76  → 0.49 tps   (NUMA 경계 → hybrid 에서는 발생 불가)
#
#   결정 = profile peak 적용:
#   - cpu_threads=32 per engine: 실측 peak. 48 은 0.3 tps 손해 + barrier
#     overhead 증가 + GPU worker core contention 위험.
#   - cpu_max_seqs=1: IPEX FD kernel 의 batch>1 KV paged-access 폭발 회피.
#     profile 에 batch 를 만든 데이터가 없으므로 최고 성능 확인된 유일한
#     구성이 batch=1. (batch>1 은 실측상 80× 느림)
#   - num_cpu_engines=2: 2 NUMA 양쪽 모두 가동 → 총 CPU throughput 2×.
#   - routing_priority=cpu-first: CPU 쪽 처리량 측정이 목적이므로 CPU 가
#     비어 있으면 CPU 로 보냄. GPU 는 CPU 둘 다 in_flight=1 일 때만.
#   - wave-batch + max_seqs=1: engine 당 직렬 파이프라인 (open → 1 req
#     admit → close → 완료 → reset). 연속적으로 req 가 흘러 들어감.
#   - cold-start gate: probe 는 GPU 로 보내 CPU 초기화 지연 회피.
#
# 기대 관찰 (실측 후 README 에 기록):
#   - engine 당 tps 가 profile peak 23 tps 에 근접하는지 (7B 는 1.5B 대비
#     weight 4.67× → per-step 200ms 추정, ~5 tps 예상)
#   - 2 engine 합산 throughput 이 single engine 의 2× 에 근접하는지
#   - CPU util NUMA 0/1 이 각각 ~95% 도달하는지 (thread pin 검증)
#   - wave lifecycle open/close/reset 주기가 per_req_latency 에 수렴하는지
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server — TP=4, 8 GPU 중 4 개만 활성
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 1024"

# -----------------------------------------------------------------------------
# Benchmark
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# CPU engine 구조 (2 NUMA)
# -----------------------------------------------------------------------------
HYBRID_NUM_CPU_ENGINES=2        # ⚠ 명시 필수. 각 NUMA 에 engine 1개씩.
HYBRID_NUMA_AWARE=true

# -----------------------------------------------------------------------------
# Per-engine 설정 — batch=1 solo decode + 32 threads
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=1           # solo decode (batch=1 IPEX FD kernel)
HYBRID_CPU_THREADS=32           # per-engine, profile 최적 (23.55 tps)
HYBRID_CPU_CORE_RATIO=1.0       # threads 명시 시 무효
HYBRID_CPU_KVCACHE_GB=0         # auto

# -----------------------------------------------------------------------------
# 라우팅 — wave-batch (max_seqs=1 에서는 사실상 throughput-adaptive 와 동일)
# -----------------------------------------------------------------------------
HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first   # CPU throughput 측정이 목적
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=25

# -----------------------------------------------------------------------------
# Logging — wave/router markers 수집 (다음 실험 시 서버 로그 저장 필수)
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=1200
SERVER_READY_POLL=5
