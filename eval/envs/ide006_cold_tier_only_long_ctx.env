# =============================================================================
# ide006_cold_tier_only_long_ctx.env — 진단 전용 변형 (TSK_012 사전 진단).
#
# Difference from ide006_cold_kv_split_on_long_ctx.env:
#   - enable_cpu_partial_attention=false   (← was true)
#   - cold-tier KV offload itself is *still active*.
#
# 의도: cold blocks 가 evict 되긴 하지만 IDE_006 의 hot/cold partition 경로는
#   비활성. 즉 cold blocks 는 vLLM 의 native reload 경로로 GPU 에 다시 들어가
#   GPU paged FA 가 처리. 같은 prompt 셋으로 vllm_original_long_ctx.env 와
#   비교했을 때:
#     * 두 결과가 lp ~3.43 발산 → cold-tier evict/reload 자체가 baseline 과
#       다른 KV source 를 만듦. TSK_012 design 확정.
#     * 두 결과가 거의 일치 → cold-tier 자체는 OK. lp ~3.43 발산은 IDE_006
#       의 hot/cold partition 경로 (CPU partial-attn + LSE merge / SDPA
#       fallback) 의 attention kernel 차이가 원인. TSK_012 design 재검토.
#
# 본 env 는 진단 회차 후 폐기 가능 — `eval/envs/` 에 임시 적재.
#
# 자세한 진단 motivation: shadow_assists/features/IDE_006/TSK_012.md §1.
# =============================================================================

# --- Model ---
MODEL=meta-llama/Llama-3.3-70B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=8
MAX_MODEL_LEN=16384

# IDE_006 (a) cold-tier KV offload 만 활성. enable_cpu_partial_attention=false 로
# IDE_006 hot/cold partition 경로는 비활성.
EXTRA_SERVE_ARGS='--kv-transfer-config={"kv_connector":"OffloadingConnector","kv_role":"kv_both","enable_cpu_partial_attention":false,"kv_connector_extra_config":{"cpu_bytes_to_use":549755813888}}'

# --- Benchmark ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=100
INPUT_LEN=14336
OUTPUT_LEN=128
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
