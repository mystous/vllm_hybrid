# =============================================================================
# G0 측정 — H100x8 · Qwen2.5-32B-AWQ · §03 THP + §04 INT4-AWQ 양자화
# -----------------------------------------------------------------------------
# ✗ 기각 (2026-04-19) — 실행 금지. 히스토리 보존용 파일.
#   사유: vLLM AWQ 커널은 CUDA 전용 (csrc/quantization/awq/gemm_kernels.cu).
#         csrc/cpu/ 에 AWQ dequant/GEMM 커널 없음.
#         hybrid 모드에서 CPU_EngineCore 가 forward 단계에서
#         ops.awq_dequantize 호출 시 CUDA kernel lookup 실패 → crash.
#   상세: NinjaGap_Todo/04_ipex_woq_int8.md "기각 근거" 참조.
#   대안: §06 VNNI hot path 에 CPU INT8 경로 편입 (csrc/cpu/gemm_vnni.cpp
#         dispatch wiring).
# =============================================================================
#
# 아래는 기각 이전 작성된 원본 주석 — 참고용:
#
# 전제:
#   1) 호스트 THP=always 상태 (setup/setup_thp_rhel.sh enable 후)
#   2) Qwen2.5-32B-Instruct-AWQ 모델이 캐시에 다운로드됨
#        huggingface-cli download Qwen/Qwen2.5-32B-Instruct-AWQ
#
# AWQ (Activation-aware Weight Quantization) 는 vLLM 이 native 로 지원.
# IPEX ipex.llm.optimize 경로 아님 — vLLM Linear layer 가 CPU 에서 AWQ kernel
# dispatch 하는지는 실측으로 확인해야 함. dispatch 안 되면 fallback BF16.
#
# 비교 대상:
#   - g0_00_32b/seqs1/          (THP off + BF16)
#   - g0_03_thp_32b/seqs1/      (THP on + BF16)
#   - 본 env 결과 (THP on + AWQ)
#
# 저장 위치: measurement_results/H100x8/g0_04_awq_32b/seqs${HYBRID_CPU_MAX_SEQS}/
# =============================================================================

HYBRID_TODO_NN=04_awq_32b
HYBRID_CPU_MAX_SEQS=1

# -----------------------------------------------------------------------------
# 모델 — AWQ INT4 양자화판 (≈18GB, 32B BF16 64GB 대비 1/3.5)
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ
PORT=8000
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# vLLM 은 AWQ 가중치를 자동 감지하지만 명시 지정해 두면 안전
EXTRA_SERVE_ARGS="--quantization awq"

NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — 2 NUMA engine
# -----------------------------------------------------------------------------
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=0
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

# -----------------------------------------------------------------------------
# 측정 infra
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=1
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100

# -----------------------------------------------------------------------------
# Ninja Gap Feature Flag
# -----------------------------------------------------------------------------
HYBRID_HUGEPAGES=1
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto

HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0

HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0

HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0

HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

# -----------------------------------------------------------------------------
# Monitor / 결과
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
