# =============================================================================
# ide006_cold_kv_long_ctx.env — IDE_006 시나리오 (long-context + OffloadingConnector).
#
#   본 env 의 활성 토글 = vLLM 내장 OffloadingConnector (cold-tier KV offload).
#   IDE_006 2 차 정의의 (a) 만 활성화. (b)(c) — CPU partial-attention worker /
#   LSE-반환 CPU kernel — 는 TSK_001 (kernel) + TSK_002 (vLLM forward 통합)
#   의 책임이며, 본 env 로 vLLM 서버를 띄워도 **TSK_001 의 portable C++
#   kernel 은 호출되지 않음** (TSK_002 미진행 상태).
#
#   따라서 본 시나리오의 검증 범위:
#     1. cold KV 가 실제로 CPU DRAM 으로 내려가는지 (server.log + monitor_cpu.csv)
#     2. 출력이 vllm_original_long_ctx.env baseline 과 의미상 일치하는지
#        (token id 직접 비교는 vllm bench serve 가 dump 안 함 — 간접 검증)
#     3. OffloadingConnector 자체의 long-context 안정성 (crash 없음)
#
#   TSK_002 가 들어와 `enable_hot_cold_split=True` 가 가능해지면 본 env 의
#   EXTRA_SERVE_ARGS 에 해당 flag 만 추가하면 e2e 테스트 (TST_003) 로 전환.
#
# 시나리오:
#   - INPUT_LEN=8192  (long-context — cold KV 발생 영역)
#   - OUTPUT_LEN=128
#   - NUM_PROMPTS=10  (적은 req)
#   - MAX_MODEL_LEN=16384
#   - GPU_MEMORY_UTIL=0.85 (OffloadingConnector 의 CPU buffer 추가 마진)
#   - cpu_bytes_to_use=4 GiB (long-context 에서 자연 증가 시 충분한 capacity)
#
# 비교 짝: vllm_original_long_ctx.env (동일 sweep + OffloadingConnector 비활성).
# 하드웨어 기준: RTX 3090 (24 GB) + Qwen2.5-7B-Instruct.
# 참고: shadow_assists/features/IDE_006/README.md
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=16384

# IDE_006 (a) — cold-tier KV offload via OffloadingConnector.
# cpu_bytes_to_use 를 long-context 시나리오에 맞게 4 GiB 로 확대 (vs short
# 시나리오의 1 GiB). RTX 3090 + 12900KF 의 시스템 RAM 안에서 안전.
EXTRA_SERVE_ARGS='--kv-transfer-config={"kv_connector":"OffloadingConnector","kv_role":"kv_both","kv_connector_extra_config":{"cpu_bytes_to_use":4294967296,"block_size":64}}'

# --- Benchmark ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=10
INPUT_LEN=8192
OUTPUT_LEN=128
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=3
