# =============================================================================
# dev_rtx3090_qwen7b_hybrid_wave.env
#
# 목적: dev 환경에서 7B + CPU batching + wave-batch 효과 검증.
#       1.5B 보다 compute/weight 비율이 훨씬 더 batching 혜택을 받는 크기.
#
# 머신: i9-12900KF (16 physical cores, AVX2 + AVX-VNNI, 1 NUMA)
#       + RTX 3090 24 GB + 62 GB RAM
#
# 참고: 이전 세션 실측 (v1 Q2, v3 F1) 기준 7B CPU decode ≈ 2.3 tok/s
#       (1 seq 전체 16 core). wave-batch + cpu_max_num_seqs=16 으로
#       weight DRAM 로드를 16 req 가 공유하면 이론상 CPU throughput 이
#       크게 오를 수 있다 — 이 env 가 그 효과의 첫 측정 지점.
#
#       반대로 GPU wall 이 CPU tail 보다 짧은 영역에서는 wave-batch 가
#       wall time 을 늘릴 가능성이 있고 (사용자 확인), 그 정량을 잡는
#       것도 목적.
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server — RTX 3090 24 GB
#   7B BF16 ≈ 14 GB weight → GPU_MEMORY_UTIL=0.90 에서 KV cache 에 ~8 GB 할당.
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# -----------------------------------------------------------------------------
# Benchmark — 500 req × 128/128 (H100 env 와 shape 통일)
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — CPU batching + wave-batch
#   HYBRID_CPU_MAX_SEQS=16  → per-engine forward pass batch M-dim
#   HYBRID_CPU_KVCACHE_GB=16 → 7B weight + batch 16 KV 용량 보수적 할당
#   HYBRID_CPU_CORE_RATIO=1.0 → 16 physical core 전부 사용
#                               (0.9 = 14 코어 실험 시 이 값 조정)
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=16
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=16
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=25

HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0

# -----------------------------------------------------------------------------
# Logging — serving silent
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
#   7B 부팅 + CPU EngineCore weight 로드 포함 → timeout 여유 있게.
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
