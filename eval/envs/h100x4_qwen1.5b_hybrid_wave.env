# =============================================================================
# h100x4_qwen1.5b_hybrid_wave.env
#
# 목적: 1.5B + CPU matmul batching + wave-batch routing 을 H100x4 에서 측정.
#       h100x4_qwen32b_hybrid_wave.env 와 완전히 동일한 hybrid 세팅으로
#       1.5B → 7B → 32B scaling 비교 가능.
#
# 하드웨어: H100 80GB HBM3 × 4 (TP=4), Xeon Platinum 8480+ (96 vCPU, 1 NUMA),
#           944 GB DDR5. AVX-512F/VNNI/BF16, AMX-BF16/INT8 실제 dispatch 확인됨
#           (Tech_done v4-F4).
#
# 모델 메모: Qwen2.5-1.5B-Instruct
#   - 1.5 B params, BF16 weight ≈ 3 GB
#   - H100x4 에서 GPU-only wall ~4s (Tech_done v4-F3)
#   - 이 scale 에서는 GPU 가 14% util 로 크게 under-saturated
#     → wave-batch 를 돌려도 CPU 요청이 GPU wall 을 초과할 가능성 큼
#       (wall time 손해 감수하고 CPU 경로가 실제로 dispatch 되는 것 확인용)
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-1.5B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# -----------------------------------------------------------------------------
# Benchmark — 500 req burst, 표준 128/128 shape
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — 32B env 와 동일 세팅
# -----------------------------------------------------------------------------
HYBRID_NUM_CPU_ENGINES=1        # H100x4 KVM 은 1 NUMA
HYBRID_NUMA_AWARE=true
HYBRID_CPU_MAX_SEQS=1           # solo decode (IPEX batch>1 병목 회피)
HYBRID_CPU_THREADS=32           # profile 최적
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_STATS_LOG_INTERVAL=25

HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0

# -----------------------------------------------------------------------------
# Logging — serving silent
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
