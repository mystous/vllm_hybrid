# =============================================================================
# ide006_cold_tier_only_value_128k.env — 가치 영역 ≥128K baseline.
#
# 10 prompts × 131072 input × 8 output / 70B + TP=8 / max_model_len=131072.
# KV size: 1.31M tokens × 320 KB / 8 worker ≈ 52 GB/worker (KV pool 46 GiB
# 의 1.13×) — KV pool 명백히 초과. baseline 이 한계 도달하는지 측정.
# =============================================================================

MODEL=meta-llama/Llama-3.3-70B-Instruct
PORT=8000
HOST=127.0.0.1

GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=8
MAX_MODEL_LEN=131072

EXTRA_SERVE_ARGS='--kv-transfer-config={"kv_connector":"OffloadingConnector","kv_role":"kv_both","enable_cpu_partial_attention":false,"kv_connector_extra_config":{"cpu_bytes_to_use":549755813888}}'

BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=10
INPUT_LEN=131072
OUTPUT_LEN=8
REQUEST_RATE=inf

MONITOR_INTERVAL=1
RESULTS_DIR=results

SERVER_READY_TIMEOUT=1800
SERVER_READY_POLL=5
