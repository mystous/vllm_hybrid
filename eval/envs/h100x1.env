# =============================================================================
# h100x1.env — H100 SXM 80GB x1, single GPU
# =============================================================================

# --- Model ---
# Use full path or HuggingFace model ID
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

# --- Server common ---
GPU_MEMORY_UTIL=0.9
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# --- Benchmark ---
NUM_PROMPTS=2000
INPUT_LEN=512
OUTPUT_LEN=512
REQUEST_RATE=inf

# --- Hybrid settings ---
# H100 x1 + Xeon 8480+ single-socket (56C/112T)
# auto-detect: cpu_max_seqs~14, kvcache~400GB, threads~56
HYBRID_CPU_MAX_SEQS=0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true           # Xeon Sapphire Rapids, NUMA-aware
HYBRID_NUM_CPU_ENGINES=1         # Single NUMA node
HYBRID_STATS_LOG_INTERVAL=50
HYBRID_ROUTING_STRATEGY=capacity

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server startup wait ---
SERVER_READY_TIMEOUT=300
SERVER_READY_POLL=5
