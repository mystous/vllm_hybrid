# =============================================================================
# dev_rtx3090_qwen7b_500.env — 500-prompt GPU vs Hybrid comparison on 7B
# i9-12900KF (16 physical cores, 1 NUMA) + RTX 3090 24GB
# =============================================================================

MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

# --- Server ---
# 7B BF16 ≈ 14 GB weight, leave the rest for KV cache on 24 GB VRAM
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# --- Benchmark (500 prompts, same shape as 1.5B run for cross-model comparison) ---
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# --- Hybrid (all CPU params on AUTO — design principle enforced by code) ---
# cpu_max_num_seqs=1 (auto), num_cpu_engines=1 (auto from NUMA)
HYBRID_CPU_KVCACHE_GB=16       # 7B weight (~14 GB) + headroom
HYBRID_CPU_THREADS=0           # auto = 16
HYBRID_NUMA_AWARE=true
HYBRID_STATS_LOG_INTERVAL=50

HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_WARMUP_REQUESTS=0

# Trace off for benchmark (would otherwise flood logs & distort timing)
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=500

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
