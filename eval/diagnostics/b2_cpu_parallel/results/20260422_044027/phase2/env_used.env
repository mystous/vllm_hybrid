# =============================================================================
# Phase 2 — CPU attention path counter 실측용 짧은 run
#
# 기존 longctx env 에서 다음만 바꿈:
#   - VLLM_HYBRID_TRACE=1  (cpu_attn.py 의 _trace_decode_path INFO 로그 emit)
#   - NUM_PROMPTS=4        (2 engine × 2 slot = 4 개만 CPU 로 가도록)
#   - OUTPUT_LEN=256       (CPU 에 간 4 req 가 짧게 끝나게)
#   - MAX_CONCURRENCY=4    (한 wave 에 다 들어가게)
#
# 목적: [HYBRID-CPU-ATTN] counter 가 heavy 조건에서 어느 path (custom_avx/
#       ipex/sdpa_batched/sdpa_loop) 로 얼마나 가는지 측정. 예상 소요 시간
#       10~20분 (16K prefill + 256 decode on CPU).
# =============================================================================

HYBRID_TODO_NN=trace_longctx_32b

MODEL=Qwen/Qwen2.5-32B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 32768 --enable-prefix-caching"

# -----------------------------------------------------------------------------
# Workload — 16K input (heavy ctx 유지) + 256 output (짧게)
# -----------------------------------------------------------------------------
DATASET_NAME=random
NUM_PROMPTS=4
INPUT_LEN=16384
OUTPUT_LEN=32
REQUEST_RATE=inf
MAX_CONCURRENCY=4

HYBRID_CPU_MAX_SEQS=2
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=10

# === Phase 2 의 핵심 ===
VLLM_HYBRID_TRACE=1              # 매 decode call 마다 path counter 찍음
VLLM_HYBRID_TRACE_EVERY=0        # TRACE=1 이면 TRACE_EVERY 무시
VLLM_HYBRID_PROFILE=0            # 부수적으로 sublayer profile 도 수집
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=10     # 10 step 마다 sublayer 분해
VLLM_HYBRID_KERNEL_TRACE=0

HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
