# =============================================================================
# Light workload trace env — X Phase 3 동작 확인용
#
# longctx env 와 같은 구조지만 128/128 workload. prefill 짧게 → CPU engine
# 이 실제로 execute_model 을 호출하고 decode 까지 돌아야 X Phase 3 의 pool
# 생성 + cpu-compute thread 확인 가능.
#
# heavy 에서는 prefill 이 너무 길어 phase3 snapshot 시점에 CPU engine 이
# 아직 scheduler loop 에 머물러 있음. light 로 하면 bench 가 ~2분에 완주.
# =============================================================================

HYBRID_TODO_NN=light_trace_32b

# -----------------------------------------------------------------------------
# X Phase 3 — Pipelined Async CPU Executor 활성화
# =1 → PipelinedCPUExecutor 사용 (execute_model 이 Future 반환, batch_queue 활성)
# =0 → 기존 UniProcExecutor (sync 동작, A/B 비교용 baseline)
# -----------------------------------------------------------------------------
HYBRID_CPU_ASYNC_EXECUTOR=1

MODEL=Qwen/Qwen2.5-32B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 2048 --enable-prefix-caching"

# -----------------------------------------------------------------------------
# Workload — 128 in / 512 out.
# CPU 4 slot (cpu_max_seqs=2 × 2 engine) 이므로 첫 4 req 가 CPU 로.
# OUTPUT 512 × CPU 속도 ~5 tok/s = 100 초. phase3 snapshot (bench 시작 후
# 60s) 이 CPU engine 의 decode 한가운데서 찍혀서 cpu-compute thread 와
# pool 상태 확인 가능.
# -----------------------------------------------------------------------------
DATASET_NAME=random
NUM_PROMPTS=8
INPUT_LEN=128
OUTPUT_LEN=512
REQUEST_RATE=inf
MAX_CONCURRENCY=8

HYBRID_CPU_MAX_SEQS=2
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=5

VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=0
VLLM_HYBRID_PROFILE_EVERY=0
VLLM_HYBRID_KERNEL_TRACE=0

HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
