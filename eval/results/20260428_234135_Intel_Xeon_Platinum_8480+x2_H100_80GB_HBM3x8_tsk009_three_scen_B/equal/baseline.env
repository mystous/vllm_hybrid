# =============================================================================
# vllm_original_long_ctx.env — long-context split-off baseline (prod).
#   Disables both cold-tier KV offload and CPU partial attention. Measures
#   vanilla GPU-only behavior on a long-context (>= 8K) workload, used as the
#   baseline against ide006_cold_kv_long_ctx.env and
#   ide006_cold_kv_split_on_long_ctx.env.
#
# Scenario:
#   - INPUT_LEN=14336  (max_model_len 16384 - output 128 - margin 1920;
#                      keeps each request near the model's per-seq ceiling
#                      so cumulative KV demand grows fastest)
#   - OUTPUT_LEN=128   (short decode — split benefit is on the prefill side)
#   - NUM_PROMPTS=100  (sized to overflow the prod GPU KV pool: prod log
#                      reports ~1,216,256 GPU KV tokens, and 100 × 14336 ≈
#                      1.43 M tokens forces ~18% of in-flight KV to spill
#                      to the cold tier — i.e. partial-attention actually
#                      fires during the split_on run rather than yielding
#                      a "lucky pass via no-fire". TSK_002 §4.5 invariant)
#   - MAX_MODEL_LEN=16384 (14K input + 128 output + headroom)
#
# Hardware reference: prod box (Intel Xeon Sapphire Rapids+ + NVIDIA H100 x 8).
# Model: meta-llama/Llama-3.3-70B-Instruct — ~140 GB BF16 weights, requires
# tensor parallel sharding. With TP=8 each H100 holds ~17.5 GB of model
# weights, leaving ~50 GB / rank for KV cache + activations.
# =============================================================================

# --- Model ---
MODEL=meta-llama/Llama-3.3-70B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
GPU_MEMORY_UTIL=0.9
TENSOR_PARALLEL_SIZE=8
MAX_MODEL_LEN=16384
EXTRA_SERVE_ARGS=""

# --- Benchmark ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=100
INPUT_LEN=8192
OUTPUT_LEN=8192
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
# Llama-3.3-70B + TP=8 takes longer to load weights and capture CUDA graphs —
# give readiness extra headroom over the 7B / TP=1 case.
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
