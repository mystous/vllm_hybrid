# =============================================================================
# vllm_original.env — vanilla baseline with all fork-side options disabled.
#   Default env for `eval/`. No cold-tier KV offload, no LMCache, no specific
#   CPU acceleration toggles. GPU-only behavior.
#   Used as the comparison baseline for option-on envs (e.g. IDE_006).
#   Hardware reference: RTX 3090 + Qwen2.5-7B-Instruct.
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
GPU_MEMORY_UTIL=0.9
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=4096
# Extra args passed directly to `vllm serve`
EXTRA_SERVE_ARGS=""

# --- Benchmark ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=200
INPUT_LEN=512
OUTPUT_LEN=256
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1   # seconds between samples

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
SERVER_READY_TIMEOUT=300
SERVER_READY_POLL=3
