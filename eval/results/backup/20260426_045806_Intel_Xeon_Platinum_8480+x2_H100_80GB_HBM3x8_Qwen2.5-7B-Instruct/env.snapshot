# =============================================================================
# vllm_original_long_ctx.env — long-context split-off baseline.
#   This env disables both cold-tier KV offload and CPU partial attention.
#   Measures vanilla GPU-only behavior on a long-context (>= 8K) workload, used
#   as the baseline against `ide006_cold_kv_long_ctx.env`.
#
# Scenario:
#   - INPUT_LEN=8192   (long-context, IDE_006 §10 (a) simulation region)
#   - OUTPUT_LEN=128   (short decode — split benefit is on the prefill side)
#   - NUM_PROMPTS=10   ("low req count" — generates enough KV-cache pressure
#                      while keeping the benchmark wall time reasonable)
#   - MAX_MODEL_LEN=16384 (8K input + 128 output + headroom)
#
# Comparison pair: ide006_cold_kv_long_ctx.env (same sweep + OffloadingConnector).
# Hardware reference: RTX 3090 (24 GB) + Qwen2.5-7B-Instruct.
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
GPU_MEMORY_UTIL=0.9
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=16384
EXTRA_SERVE_ARGS=""

# --- Benchmark ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=10
INPUT_LEN=8192
OUTPUT_LEN=128
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
# Long-context models take longer to capture CUDA graphs — give readiness more headroom.
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=3
