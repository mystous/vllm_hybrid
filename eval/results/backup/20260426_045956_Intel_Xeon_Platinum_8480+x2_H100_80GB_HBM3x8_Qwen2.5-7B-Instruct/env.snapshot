# =============================================================================
# ide006_cold_kv_long_ctx.env — IDE_006 scenario (long-context + OffloadingConnector).
#
#   The active toggle in this env is the vLLM built-in OffloadingConnector
#   (cold-tier KV offload). Only IDE_006 second-cut item (a) is enabled.
#   Items (b) and (c) — CPU partial-attention worker / LSE-returning CPU
#   kernel — are owned by TSK_001 (kernel) and TSK_002 (vLLM forward
#   integration); when running the vLLM server with this env, **the TSK_001
#   portable C++ kernel is NOT invoked** because TSK_002 has not landed yet.
#
#   What this scenario therefore validates:
#     1. Whether cold KV actually moves to CPU DRAM (server.log + monitor_cpu.csv).
#     2. Whether the output is semantically consistent with the
#        vllm_original_long_ctx.env baseline (`vllm bench serve` does not dump
#        token ids — indirect verification).
#     3. OffloadingConnector long-context stability on its own (no crashes).
#
#   Once TSK_002 lands and `enable_hot_cold_split=True` becomes available,
#   add that flag to EXTRA_SERVE_ARGS to switch this env into the e2e test
#   path (TST_003).
#
# Scenario:
#   - INPUT_LEN=8192    (long-context — region where cold KV occurs)
#   - OUTPUT_LEN=128
#   - NUM_PROMPTS=10    (low req count)
#   - MAX_MODEL_LEN=16384
#   - GPU_MEMORY_UTIL=0.85 (extra margin for the OffloadingConnector CPU buffer)
#   - cpu_bytes_to_use=4 GiB (enough capacity as long-context naturally grows)
#
# Comparison pair: vllm_original_long_ctx.env (same sweep, OffloadingConnector off).
# Hardware reference: RTX 3090 (24 GB) + Qwen2.5-7B-Instruct.
# See: shadow_assists/features/IDE_006/README.md
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=16384

# IDE_006 (a) — cold-tier KV offload via OffloadingConnector.
# cpu_bytes_to_use is bumped to 4 GiB for the long-context scenario (vs 1 GiB
# for the short scenario). Stays within system RAM on RTX 3090 + 12900KF.
EXTRA_SERVE_ARGS='--kv-transfer-config={"kv_connector":"OffloadingConnector","kv_role":"kv_both","kv_connector_extra_config":{"cpu_bytes_to_use":4294967296,"block_size":64}}'

# --- Benchmark ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=10
INPUT_LEN=8192
OUTPUT_LEN=128
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=3
