# =============================================================================
# ide006_cold_kv_split_on_long_ctx.env — TSK_002 Phase 4c feature-on (prod).
#
# Combines:
#   - meta-llama/Llama-3.3-70B-Instruct, TP=8 (long-context prod baseline).
#   - OffloadingConnector cold-tier KV offload.
#   - enable_cpu_partial_attention=True — model_runner routes the cold prefix
#     of each request through TSK_001's CPU partial-attention kernel and
#     merges with the GPU hot-suffix output via merge_attn_states (TSK_002
#     Phase 4c dispatcher).
#
# Comparison axis (when run alongside the other long_ctx envs):
#   * vllm_original_long_ctx.env          — no offload, no split (baseline).
#   * ide006_cold_kv_long_ctx.env         — offload only (cold KV evicts to
#                                            CPU but never read in place).
#   * ide006_cold_kv_split_on_long_ctx.env — offload + split (this env, full
#                                             feature on).
#
# Phase 4c invariant: requires block_size_factor=1, which is satisfied here
# by omitting `block_size` from kv_connector_extra_config (default factor=1).
# See: shadow_assists/features/IDE_006/README.md
# =============================================================================

# --- Model ---
MODEL=meta-llama/Llama-3.3-70B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=8
MAX_MODEL_LEN=16384

# IDE_006 (a) cold-tier KV offload + (b) CPU partial-attention dispatcher.
# `enable_cpu_partial_attention` is a top-level KVTransferConfig field; placed
# alongside kv_connector / kv_role rather than inside kv_connector_extra_config.
EXTRA_SERVE_ARGS='--kv-transfer-config={"kv_connector":"OffloadingConnector","kv_role":"kv_both","enable_cpu_partial_attention":true,"kv_connector_extra_config":{"cpu_bytes_to_use":549755813888}}'

# --- Benchmark ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=100
INPUT_LEN=14336
OUTPUT_LEN=128
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
