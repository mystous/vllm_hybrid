# =============================================================================
# ide006_cold_kv.env — IDE_006 (Cold-KV CPU Partial Attention) 의 2 차 정의 중
#   현재 코드에 토글이 존재하는 부분만 활성화하는 env.
#
# IDE_006 2 차 정의 = (a) cold-tier KV offload + (b) CPU partial-attention
#   worker + (c) LSE-반환 CPU kernel + (d) merge_attn_states 합산.
#   현재 (b)(c) 는 미구현이므로 본 env 는 (a) 만 활성화한다.
#   참고: shadow_assists/features/IDE_006/README.md
#
# 활성화 내용:
#   - vLLM 내장 OffloadingConnector (외부 의존 없음. CPUOffloadingSpec 기본).
#   - cpu_bytes_to_use: 1 GiB (RTX 3090 + 128/128 workload 에서 보수적 시작값.
#     workload 가 long-context 로 전환되면 늘려야 함)
#   - block_size: 64 (vLLM doc 표준 예시)
#
# 비교 baseline: vllm_original.env (옵션 모두 끔, GPU-only).
# 하드웨어 기준: RTX 3090 + Qwen2.5-7B-Instruct.
# 참고 패턴: docs/features/disagg_prefill.md:44,
#           tests/v1/kv_offload/test_cpu_offloading.py:197
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000
HOST=127.0.0.1

# --- Server ---
# OffloadingConnector 가 CPU DRAM 측에 추가 KV buffer 를 요구하므로
# GPU memory util 을 약간 낮춰 두 측의 안전 마진을 확보.
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=4096

# IDE_006 (a): cold-tier KV offload via OffloadingConnector.
# JSON 은 공백 없이 single-quote 로 감싼다 (env-file source 시 안전).
EXTRA_SERVE_ARGS='--kv-transfer-config={"kv_connector":"OffloadingConnector","kv_role":"kv_both","kv_connector_extra_config":{"cpu_bytes_to_use":1073741824,"block_size":64}}'

# --- Benchmark (vllm_original.env 와 동일) ---
BACKEND=vllm
DATASET_NAME=random
NUM_PROMPTS=200
INPUT_LEN=512
OUTPUT_LEN=256
REQUEST_RATE=inf

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

# --- Server readiness ---
SERVER_READY_TIMEOUT=300
SERVER_READY_POLL=3
