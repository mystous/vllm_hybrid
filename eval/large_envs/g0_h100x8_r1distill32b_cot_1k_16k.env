# =============================================================================
# Reasoning / CoT 32B — DeepSeek-R1-Distill-Qwen-32B × H100x8 TP=8
# 1K in / 16K out (long decode)
# =============================================================================
#
# 목적: 32B 에서 긴 decode (reasoning) 를 돌리는 workload. 70B CoT env 와 대응.
#   - 32B 는 70B 대비 per-token 빠름 → 같은 시간에 더 긴 output 뽑음
#   - reasoning 긴 <think> chain 이 decode 를 지배하므로 KV 누적 심각
#
# 왜 DeepSeek-R1-Distill-Qwen-32B 인가:
#   - Qwen2.5-32B 베이스에 R1 reasoning 증류
#   - 실제 <think>...</think> 긴 CoT 생성 (Qwen2.5-32B-Instruct 는 짧게 끝남)
#   - 32B 동일 스펙 (64 layers, 8 kv_heads, 128 head_dim)
#   - KV per token ≈ 256 KB, at 17K total ctx ≈ 4.35 GB/req
#
# 검증 대상 기법:
#   - KV cold tier (decode 후반 누적 KV → CPU)
#   - Host control-path 부하 (long decode = step 수 많음, B1 가설)
#   - ScoutAttention layer-ahead
# =============================================================================

HYBRID_TODO_NN=cot_r1distill32b

MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-32B
PORT=8000
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 17500 --enable-prefix-caching"
                                # 1K input + 16K output 여유 포함

# -----------------------------------------------------------------------------
# Workload — 1K input + 16K output (decode 지배)
# -----------------------------------------------------------------------------
DATASET_NAME=random
NUM_PROMPTS=100
INPUT_LEN=1024
OUTPUT_LEN=16384
REQUEST_RATE=inf
MAX_CONCURRENCY=100             # KV 4.35 GB × 100 = 435 GB (여유 남김)

HYBRID_CPU_MAX_SEQS=4
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100
VLLM_HYBRID_KERNEL_TRACE=0

HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
