# =============================================================================
# Variable-length workload — Qwen2.5-72B × H100x8 TP=8 × sonnet dataset
# =============================================================================
#
# 목적: 고정 길이 random 대신 sonnet.txt 에서 **자연 가변 길이** prompt 사용
#   - 실제 production 트래픽에 가까움
#   - length 분산이 scheduler behavior / batch stability 에 미치는 영향 측정
#   - prefix cache reuse 가능 (shared prefix prompt)
#
# Sonnet dataset: vLLM repo 의 benchmarks/sonnet.txt (Shakespeare sonnets 자연
# 언어). benchmark_serving.py 가 이걸 chunk 로 샘플링. shared prefix 포함.
#
# 검증 대상 기법:
#   - Prefix caching 실제 hit rate
#   - Variable-length batching stability
#   - p50/p95/p99 latency 분포
# =============================================================================

HYBRID_TODO_NN=sonnet_72b

MODEL=Qwen/Qwen2.5-72B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 9000 --enable-prefix-caching --enable-chunked-prefill"

# -----------------------------------------------------------------------------
# Sonnet workload — 가변 길이
# -----------------------------------------------------------------------------
DATASET_NAME=sonnet
DATASET_PATH=benchmarks/sonnet.txt
SONNET_INPUT_LEN=8192           # shared prefix 포함 input 길이
SONNET_PREFIX_LEN=2048          # shared prefix 부분 (prefix cache hit 대상)
SONNET_OUTPUT_LEN=512
NUM_PROMPTS=300
REQUEST_RATE=inf
MAX_CONCURRENCY=80

# -----------------------------------------------------------------------------
# Hybrid / infra (이하 baseline 동일)
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=4
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100
VLLM_HYBRID_KERNEL_TRACE=0

HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
