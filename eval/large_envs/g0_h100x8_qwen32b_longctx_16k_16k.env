# =============================================================================
# Long-context 32B — Qwen2.5-32B × H100x8 TP=8 × 16K in / 16K out
# =============================================================================
#
# 목적: 32B 에서 KV 압박을 실제로 내기 위한 workload.
#   32B 는 weight 가 64GB 로 가벼워서 (TP=8 → 8GB/GPU) 72B 보다 HBM 여유 큼.
#   따라서 72B 의 8K/8K 보다 훨씬 긴 context + 높은 concurrency 로 압박해야 함.
#
# KV 계산 (Qwen2.5-32B: 64 layers, 8 KV heads GQA, 128 head_dim, BF16):
#   KV per token   = 2 × 64 × 8 × 128 × 2 bytes = 256 KB
#   KV per req @ 32K ctx = 256 KB × 32,768 = 8.4 GB
#   Weight BF16    = 64 GB → TP=8 → 8 GB/GPU
#   H100 80GB - 8 GB weight - ~10 GB activation = ~62 GB free/GPU
#   8 GPU 합 KV 예산 = 496 GB
#   최대 동시 at 32K = 496 / 8.4 ≈ 59 reqs (HBM 포화 직전)
#
# 이 설정에서 기존 128/128 baseline (KV 4MB/req, HBM 0.5% 사용) 과 체제가
# 완전히 다름. B2 실험의 핵심 후보 workload.
# =============================================================================

HYBRID_TODO_NN=longctx_32b

MODEL=Qwen/Qwen2.5-32B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 33000 --enable-prefix-caching"
                                # Qwen2.5-32B 기본 32K context 지원. 여유 1K

# -----------------------------------------------------------------------------
# Workload — 16K input + 16K output (total 32K ctx)
# -----------------------------------------------------------------------------
DATASET_NAME=random
NUM_PROMPTS=100                 # 32K context 는 req 당 시간 길어서 축소
INPUT_LEN=16384
OUTPUT_LEN=16384
REQUEST_RATE=inf
MAX_CONCURRENCY=55              # HBM 포화 직전 상한

# -----------------------------------------------------------------------------
# Hybrid / infra (baseline 동일)
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=4
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100
VLLM_HYBRID_KERNEL_TRACE=0

HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
