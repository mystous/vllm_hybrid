# =============================================================================
# Qwen3-235B-A22B (MoE, 22B active) × H100x8 TP=8 × 8K in / 2K out
# =============================================================================
#
# 모델 스펙:
#   - Qwen3-235B-A22B-Instruct-2507: MoE, 235B total / 22B active per token
#   - FP8 또는 BF16 checkpoint 존재
#   - weight BF16: 470 GB → TP=8 → 59 GB/GPU (HBM 빡빡하지만 가능)
#   - weight FP8: 235 GB → TP=8 → 30 GB/GPU (여유 있음, 권장)
#   - Qwen3 architecture: GQA + longer context support (최대 128K)
#
# 권장: FP8 버전 사용 (Qwen/Qwen3-235B-A22B-Instruct-2507-FP8 if available,
#       또는 `--quantization fp8` 로 런타임 양자화)
#
# 목적: 300B 급 MoE workload. R1 보다 작지만 더 안정적 테스트 대상.
#   - Active 22B 만 실제 compute → per-token 속도는 22B dense 와 비슷
#   - 총 235B weight 는 expert routing 으로 분산
#
# 검증 대상:
#   - MoE expert routing overhead
#   - 긴 context (Qwen3 는 128K 지원) 에서 KV 점유율
# =============================================================================

HYBRID_TODO_NN=qwen3_235b_moe

MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
PORT=8000
GPU_MEMORY_UTIL=0.92
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 11000 --trust-remote-code --enable-prefix-caching --enable-chunked-prefill --quantization fp8"

# -----------------------------------------------------------------------------
# Workload — 8K in / 2K out
# -----------------------------------------------------------------------------
DATASET_NAME=random
NUM_PROMPTS=100
INPUT_LEN=8192
OUTPUT_LEN=2048
REQUEST_RATE=inf
MAX_CONCURRENCY=40

HYBRID_CPU_MAX_SEQS=4
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100
VLLM_HYBRID_KERNEL_TRACE=0

HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=1500
SERVER_READY_POLL=10
