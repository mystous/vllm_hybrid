# =============================================================================
# h100x4_qwen7b_hybrid_500.env — 500-prompt main burst on H100x4 + Xeon 8480+
# Target: dev v3 F1/F2 (GPU 5.8 tok/s, CPU 2.3 tok/s @ 7B) 와 직접 대조.
#         H100 에서 GPU 처리량 및 CPU (AMX/VNNI) 처리량을 재측정.
# =============================================================================

MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

# --- Server ---
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# --- Benchmark (dev 500 req 와 동일 shape, cross-env 비교용) ---
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# --- Hybrid (전부 auto) ---
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=50

HYBRID_ROUTING_STRATEGY=throughput-adaptive
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_WARMUP_REQUESTS=0

# 본 벤치 는 trace off — 로그 I/O 로 timing 왜곡 방지
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=500

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
