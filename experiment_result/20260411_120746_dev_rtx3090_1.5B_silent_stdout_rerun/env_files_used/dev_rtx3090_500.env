# =============================================================================
# dev_rtx3090_500.env — 500-prompt GPU vs Hybrid comparison on dev box
# i9-12900KF (16P/24L, AVX2/AVX-VNNI) + RTX 3090 24GB
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-1.5B-Instruct
PORT=8000

# --- Server common ---
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# --- Benchmark (500 prompts, INPUT/OUTPUT typical) ---
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# --- Hybrid settings ---
# 16 physical cores → all bound 1:1 via _C_utils.init_cpu_threads_env
HYBRID_CPU_MAX_SEQS=1
HYBRID_CPU_KVCACHE_GB=8
HYBRID_CPU_THREADS=0          # auto = 16
HYBRID_NUMA_AWARE=false
HYBRID_NUM_CPU_ENGINES=1
HYBRID_STATS_LOG_INTERVAL=50

HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=2048
HYBRID_WARMUP_REQUESTS=0

# --- Trace (production bench = silent) ---
# default: VLLM_HYBRID_TRACE=0, VLLM_HYBRID_TRACE_EVERY=0 (unset)
# For smoke/debug set VLLM_HYBRID_TRACE=1 explicitly.
VLLM_HYBRID_TRACE=0

# --- Monitoring ---
MONITOR_INTERVAL=1

# --- Results ---
RESULTS_DIR=results

SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=5
