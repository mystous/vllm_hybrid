# =============================================================================
# G0 측정 template — dev (RTX3090 + i9-12900KF, Qwen2.5-1.5B)
# =============================================================================
#
# 목적: Ninja Gap 성능 추적의 **baseline (pre-measurement) template**.
#       이 파일을 복사 → HYBRID_CPU_MAX_SEQS 값만 바꿔가며 serve/bench 반복.
#
# 저장 위치: measurement_results/RTX3090/g0_${HYBRID_TODO_NN}/seqs${HYBRID_CPU_MAX_SEQS}/
#           (serve.sh / bench.sh 가 PROFILE=1 시 자동 산출)
#
# 사용법:
#   1) 이 파일을 복사: cp g0_dev_rtx3090_qwen1.5b.env /tmp/run.env
#   2) HYBRID_TODO_NN 을 현재 측정 라운드 번호로 (00=baseline, 05=§05 적용 후 …)
#   3) 이번 sweep 의 HYBRID_CPU_MAX_SEQS 값 설정 (1/2/4/8/16 각각 재실행)
#   4) ./eval/serve.sh hybrid /tmp/run.env  (터미널 1)
#   5) ./eval/bench.sh hybrid /tmp/run.env  (터미널 2, ready 후)
#
# =============================================================================

# -----------------------------------------------------------------------------
# 측정 라운드 식별 — 이 env 로 측정한 결과가 어느 디렉토리로 갈지 결정
# -----------------------------------------------------------------------------
# TODO 번호 (NinjaGap_Todo/NN_*.md 의 NN):
#   00 = baseline (아무 Ninja Gap 기법 미적용, 측정 infra 만)
#   03 = §03 Huge Pages 1GB 적용 후
#   04 = §04 IPEX WoQ INT8 적용 후
#   05 = §05 KMP_BLOCKTIME 적용 후   ← 현재 구현 상태
#   06 = §06 Hot Path Wiring 적용 후 (G1 진입)
#   07 = §07 ISA Binary Dispatch 적용 후
#   08 = §08 Kernel Fusion 적용 후
#   … (NinjaGap_Todo/README.md "문서 인덱스" 참조)
HYBRID_TODO_NN=02_strat_throughput_adaptive

# 이번 run 의 CPU batch 크기 (sweep: 1, 2, 4, 8, 16 각각 별도 run)
HYBRID_CPU_MAX_SEQS=1

# -----------------------------------------------------------------------------
# 모델 / 워크로드
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8765
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 1024"

NUM_PROMPTS=100
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=1.0

# -----------------------------------------------------------------------------
# Hybrid — 기본 구조
# -----------------------------------------------------------------------------
HYBRID_NUM_CPU_ENGINES=1
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=16
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=throughput-adaptive
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=10
HYBRID_STATS_LOG_INTERVAL=5

# -----------------------------------------------------------------------------
# 측정 infra — 항상 ON (측정 env 의 역할)
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=1            # sublayer hook + manifest 활성
VLLM_HYBRID_PROFILE_SUBLAYER=1   # qkv/o/gate_up/down/norm/act 세분화
VLLM_HYBRID_PROFILE_EVERY=1      # 매 step 기록 (짧은 bench 에서도 확실)

# -----------------------------------------------------------------------------
# Ninja Gap 기법 Feature Flag — TODO NN 에 따라 on/off
# (flag 이름: NinjaGap_Todo/README.md 의 "기법 Feature Flag 테이블")
# -----------------------------------------------------------------------------
# Tier 0
HYBRID_HUGEPAGES=0               # §03
HYBRID_WOQ_INT8=0                # §04
HYBRID_KMP_BLOCKTIME=auto        # §05 (auto=KMP_BLOCKTIME=0 강제, 현재 구현됨)

# Tier 1 — hot path
HYBRID_VNNI_HOT_PATH=0           # §06
HYBRID_ISA_DISPATCH=auto         # §07
HYBRID_KERNEL_FUSION=0           # §08
HYBRID_LUT_SOFTMAX=0             # §09
HYBRID_LUT_SILU=0                # §09

# Tier 2 — batch scaling
HYBRID_HEAD_FOLDING=0            # §10
HYBRID_BATCH_AWARE_ATTN=off      # §11
HYBRID_PERSISTENT_OMP=0          # §12

# Tier 2 — big wins
HYBRID_TMAC_LUT_INT4=0           # §13
HYBRID_AVX_AMX_CASCADE=0         # §14
HYBRID_AMX_PREPACK=auto          # §15 (auto=IPEX 내부)
HYBRID_SPARSE_BITMASK=0          # §16

# Tier 3 / 병행 / 장거리 — 보통 미사용
HYBRID_CORE_GROUP_PIPELINE=0     # §17
HYBRID_SPEC_DECODE_CPU=0         # §18
HYBRID_PD_DISAGG=0               # §19
HYBRID_KV_OFFLOAD=0              # §20
HYBRID_SCOUT_ATTN=0              # §21
HYBRID_NEO_ASYMMETRIC=0          # §22

# -----------------------------------------------------------------------------
# Monitor / 결과
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=2
RESULTS_DIR=results
SERVER_READY_TIMEOUT=180
SERVER_READY_POLL=3
