# =============================================================================
# dev_rtx3090_qwen1.5b_hybrid_wave4.env
#
# 목적: 1.5B + wave-batch 인데 wave 크기를 4 로 축소해서 CPU tail 이
#       wall 을 어느 정도 덜 끌어내는지 측정. wave=16 대비 비교.
#
# 차이: HYBRID_CPU_MAX_SEQS=16 → 4
#       (다른 세팅 전부 dev_rtx3090_qwen1.5b_hybrid_wave.env 와 동일)
# =============================================================================

MODEL=Qwen/Qwen2.5-1.5B-Instruct
PORT=8000

GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# wave=4 (16 → 4)
HYBRID_CPU_MAX_SEQS=4
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=8
HYBRID_CPU_THREADS=0
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=0
HYBRID_STATS_LOG_INTERVAL=25

HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0

VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=5
