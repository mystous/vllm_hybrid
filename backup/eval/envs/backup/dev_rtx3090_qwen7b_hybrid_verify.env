# =============================================================================
# dev_rtx3090_qwen7b_hybrid_verify.env
#
# Purpose: verify that the hybrid design works end-to-end on 7B.
#   1. GPU engine actually processes GPU-routed requests
#   2. CPU engine actually processes CPU-routed requests (IPEX path)
#   3. A single CPU request saturates every core on the NUMA node
#   4. Routing / dispatch / scheduler / executor / output paths all work
#
# This is NOT a benchmark. Performance numbers are ignored.  Only logs and
# per-thread CPU utilization matter.
#
# Host: i9-12900KF (16 physical cores, 1 NUMA node) + RTX 3090 24GB
# =============================================================================

# --- Model ---
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

# --- Server ---
# 7B BF16 = ~14 GB weight on GPU; leave room for small KV cache.
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# Shrink max model len so 7B weights + KV cache fit in 24 GB VRAM with margin
EXTRA_SERVE_ARGS="--max-model-len 4096"

# --- Verification workload (not a benchmark) ---
# Small enough to finish in tens of seconds.  Short prompts so CPU prefill
# doesn't dominate verification time.
NUM_PROMPTS=8
INPUT_LEN=64
OUTPUT_LEN=32
REQUEST_RATE=inf

# --- Hybrid settings ---
# KEY POINT: cpu_max_num_seqs and num_cpu_engines are NOT set here.  They
# default to 0 (auto).  _resolve_cpu_params + launch_hybrid_engines will
# derive them from NUMAAllocator:
#   dev (1 NUMA)  → num_cpu_engines=1, cpu_max_num_seqs=1
#   H100 2-NUMA   → num_cpu_engines=2, cpu_max_num_seqs=1 per engine
# If either is wrong, the [HYBRID-RESOLVE] / [HYBRID-LAUNCH] logs expose it.
HYBRID_CPU_KVCACHE_GB=16       # 7B weight (14 GB) + KV cache headroom
HYBRID_CPU_THREADS=0           # auto = 16 physical cores on this NUMA node
HYBRID_NUMA_AWARE=true         # required so num_cpu_engines picks up NUMA count

# Routing: capacity + cpu-first — paper Algorithm 1 + Property 2
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_WARMUP_REQUESTS=0       # skip EMA warmup for a deterministic verification

HYBRID_STATS_LOG_INTERVAL=1    # log router stats every completion

# --- Trace: every execute_model step, every decode attn call ---
# These fire per-call so the log will be big, but this is exactly what
# we need to prove the path.
VLLM_HYBRID_TRACE=1
VLLM_HYBRID_TRACE_EVERY=1

# --- Monitor + results ---
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900       # 7B first boot takes longer
SERVER_READY_POLL=5
