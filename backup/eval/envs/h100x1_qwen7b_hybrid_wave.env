# =============================================================================
# h100x1_qwen7b_hybrid_wave.env
#
# 목적: h100x4_qwen7b_hybrid_wave.env 의 single-GPU 변형.
#       TP=4 → TP=1. 나머지 hybrid 세팅 모두 동일.
#
# 하드웨어: H100 80GB HBM3 × 1, Xeon Platinum 8480+ (96 vCPU, 1 NUMA),
#           944 GB DDR5. AMX-BF16 brgemm dispatch 경로 유지.
#
# 모델 메모: Qwen2.5-7B-Instruct
#   - 7 B params, BF16 weight ≈ 14 GB (TP=1 이므로 단일 GPU 에 전부 로드)
#   - H100x1 80GB 에서 weight 14GB + KV cache + activation 여유 50GB+
#   - H100x4 (TP=4, 3.5GB/GPU) 대비 per-step compute 시간 ~4x 증가 예상
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-7B-Instruct
PORT=8000

# -----------------------------------------------------------------------------
# Server — H100x1 TP=1
# -----------------------------------------------------------------------------
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 4096"

# -----------------------------------------------------------------------------
# Benchmark — 500 req burst, 표준 128/128 shape
# -----------------------------------------------------------------------------
NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — H100x4 env 와 동일
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=1
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_CPU_THREADS=24
HYBRID_NUMA_AWARE=true
HYBRID_NUM_CPU_ENGINES=1
HYBRID_STATS_LOG_INTERVAL=25

HYBRID_ROUTING_STRATEGY=wave-batch
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0

# -----------------------------------------------------------------------------
# Logging — serving silent
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0

# -----------------------------------------------------------------------------
# Monitoring / results
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=1200
SERVER_READY_POLL=5
