# =============================================================================
# Reasoning / CoT workload — DeepSeek-R1-Distill-Llama-70B × H100x8 TP=8
# 1K in / 16K out (long decode)
# =============================================================================
#
# 목적: 긴 decode (reasoning chain-of-thought) 에서 KV 가 누적되는 워크로드.
#   - Input 1K → prefill 작음
#   - Output 16K → decode 매우 길음 → KV 누적으로 HBM 압박 점진 증가
#   - reasoning 은 토큰 단위 critical path → host control-path 병목 (Blink)
#
# 왜 DeepSeek-R1-Distill-Llama-70B 인가:
#   - Llama-3.3-70B 위에 DeepSeek-R1 reasoning 증류 (실제로 긴 <think>...</think> 생성)
#   - 16K output 생성 시 실제로 reasoning 내용을 다 뱉음 (Qwen 은 짧게 끝남)
#   - Llama-3.3 spec: 80 layers, 8 kv_heads (GQA), 128 head_dim
#   - KV per token (BF16) ≈ 320 KB, at 17K total ctx ≈ 5.44 GB/req
#
# 검증 대상 기법:
#   - KV cold tier (decode 후반부 누적 KV 를 CPU 로)
#   - ScoutAttention (layer-ahead precompute)
#   - Host control-path profiling (Blink hypothesis)
# =============================================================================

HYBRID_TODO_NN=cot_r1distill70b

MODEL=deepseek-ai/DeepSeek-R1-Distill-Llama-70B
PORT=8000
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 17000 --enable-prefix-caching"

# -----------------------------------------------------------------------------
# Workload — 1K input + 16K output (decode 지배)
# -----------------------------------------------------------------------------
DATASET_NAME=random
NUM_PROMPTS=100                 # 16K output 은 req 당 시간 길어서 줄임
INPUT_LEN=1024
OUTPUT_LEN=16384
REQUEST_RATE=inf
MAX_CONCURRENCY=60              # 17K context 기준 KV 약 325GB

HYBRID_CPU_MAX_SEQS=4
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100
VLLM_HYBRID_KERNEL_TRACE=0

HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
