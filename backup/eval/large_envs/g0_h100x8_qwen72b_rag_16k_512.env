# =============================================================================
# RAG / long-prompt workload — Qwen2.5-72B × H100x8 TP=8 × 16K in / 512 out
# =============================================================================
#
# 목적: RAG / 문서 요약 / 긴 system prompt 시나리오. prefill 이 지배적.
#   - Input 16K → prefill compute 매우 커짐 (chunked prefill 효과 검증)
#   - Output 512 → decode 는 짧음
#   - Shared system prompt 있으면 prefix cache 효과 측정 가능
#
# KV per req at 16K ctx ≈ 5.12 GB (Qwen2.5-72B 계산 동일)
# 주 병목: prefill compute (GPU tensor core 포화) → CPU prefill-assist 여지
#
# 검증 대상 기법:
#   - Prefix caching (shared system prompt)
#   - Chunked prefill
#   - (잠재) CPU-side prefill-assist (ideation 2-6)
# =============================================================================

HYBRID_TODO_NN=rag_72b

MODEL=Qwen/Qwen2.5-72B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 17000 --enable-prefix-caching --enable-chunked-prefill --long-prefill-token-threshold 2048"

# -----------------------------------------------------------------------------
# Workload — 16K input, 512 output (prefill 지배)
# -----------------------------------------------------------------------------
DATASET_NAME=random
NUM_PROMPTS=200
INPUT_LEN=16384
OUTPUT_LEN=512
REQUEST_RATE=inf
MAX_CONCURRENCY=60              # 16K context 기준 KV 약 300GB 사용

# -----------------------------------------------------------------------------
# Hybrid / infra (이하 baseline 동일)
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=4
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100
VLLM_HYBRID_KERNEL_TRACE=0

HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
