# =============================================================================
# Bursty workload — Qwen2.5-72B × H100x8 TP=8 × 2K/2K × Poisson arrival 32/s
# =============================================================================
#
# 목적: realistic online serving 패턴. 무한 동시 (rate=inf) 대신 Poisson arrival
#   - TTFT / p95/p99 tail latency 가 의미 있는 지표가 됨
#   - scheduler overhead / admission control 병목 노출
#   - KV 점유율이 시간에 따라 변동 → tier 정책이 영향을 받음
#
# KV per req at 4K total ctx ≈ 1.28 GB (Qwen 72B)
# rate=32/s × 평균 처리 시간 → 시간마다 동시 in-flight 변동
#
# 검증 대상 기법:
#   - Scheduler overhead profile (Blink)
#   - TTFT tail control
#   - Admission control
# =============================================================================

HYBRID_TODO_NN=burst_72b

MODEL=Qwen/Qwen2.5-72B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.90
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 5000 --enable-prefix-caching"

# -----------------------------------------------------------------------------
# Workload — 2K/2K + Poisson rate 32 req/s
# -----------------------------------------------------------------------------
DATASET_NAME=random
NUM_PROMPTS=1000                # 충분히 길게 돌려야 burst pattern 관찰 가능
INPUT_LEN=2048
OUTPUT_LEN=2048
REQUEST_RATE=32                 # Poisson arrival (초당 32 req 기대)
MAX_CONCURRENCY=0               # 제한 없음 (실제 arrival 이 정함)

HYBRID_CPU_MAX_SEQS=4
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100
VLLM_HYBRID_KERNEL_TRACE=0

HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
