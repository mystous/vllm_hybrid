# =============================================================================
# Extreme-scale reasoning — DeepSeek-R1 671B (MoE, FP8) × H100x8 TP=8
# 4K in / 8K out
# =============================================================================
#
# 주의: 이 설정은 **호스트에서 반드시 재빌드/재검증 필요**. 작동 조건 까다로움.
#
# 모델 스펙:
#   - 671B total params (MoE, 37B active per token)
#   - MLA (Multi-head Latent Attention): KV cache 압축 — per token 1~2 KB 수준
#   - 공식 FP8 checkpoint (deepseek-ai/DeepSeek-R1)
#   - weight FP8: 671B × 1 byte = 671 GB
#   - H100x8 = 640 GB HBM → **활성 experts 만 HBM 유지 + 나머지 CPU offload 필요**
#     (KTransformers-style MoE expert offload 가 이 지점에서 실전 가치)
#
# vLLM 지원 상태:
#   - 2024-12 이후 vLLM 이 DeepSeek-V3/R1 지원 (TP=8 on H100x8)
#   - MoE expert parallelism + FP8 활성화 필요: `--quantization fp8` (또는 native)
#   - 최신 vLLM release 확인 필수 (구 버전은 미지원)
#
# 검증 대상 기법:
#   - MoE expert offload (KTransformers 방식) — CPU 가 일부 expert 상주
#   - KV cold tier (장기 decode)
#   - Reasoning workload 의 long decode 효과 (R1 은 <think> 매우 김)
# =============================================================================

HYBRID_TODO_NN=ds_r1_671b

MODEL=deepseek-ai/DeepSeek-R1
PORT=8000
GPU_MEMORY_UTIL=0.95            # 극단적 HBM 활용
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 13000 --trust-remote-code --enable-prefix-caching --quantization fp8"
                                # MLA 가 KV 작아서 더 긴 context 가능하지만 보수적으로
                                # --trust-remote-code 는 DeepSeek tokenizer 용

# -----------------------------------------------------------------------------
# Workload — 4K input + 8K output (R1 reasoning 길게 뽑기)
# -----------------------------------------------------------------------------
DATASET_NAME=random
NUM_PROMPTS=50                  # 671B 는 per-req 시간 길어서 소량
INPUT_LEN=4096
OUTPUT_LEN=8192
REQUEST_RATE=inf
MAX_CONCURRENCY=16              # MoE + 큰 모델 → 동시성 상한 보수적

HYBRID_CPU_MAX_SEQS=4
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=20

VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100
VLLM_HYBRID_KERNEL_TRACE=0

HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

MONITOR_INTERVAL=2
RESULTS_DIR=results
SERVER_READY_TIMEOUT=1800       # 671B 로딩 오래 걸림
SERVER_READY_POLL=10
