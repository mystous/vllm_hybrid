# =============================================================================
# Long-context workload — Qwen2.5-72B × H100x8 TP=8 × 8K in / 8K out
# =============================================================================
#
# 목적: KV cache 를 실제로 GPU HBM 을 압박하는 지점까지 쓰는 workload.
#       기존 128/128 baseline 은 HBM 여유가 너무 커서 CPU shadow 효과를 못 봄.
#
# 왜 이 설정인가:
#   Qwen2.5-72B: num_layers=80, kv_heads=8 (GQA), head_dim=128
#   KV per token (BF16)   = 2 × 80 × 8 × 128 × 2 bytes = 320 KB
#   KV per req at 16K ctx = 320KB × 16,384 = 5.12 GB
#   Weight 72B BF16       = 144 GB → TP=8 → 18 GB/GPU
#   H100 80GB - 18 GB weight - ~10 GB activation/CUDA = ~52 GB free/GPU
#   8 GPU 합 = 416 GB KV 예산
#   최대 동시 at 16K      = 416 / 5.12 ≈ 81 reqs (HBM 포화 직전)
#
# 이 workload 에서 KV cold tier / InfiniGen prefetch / ScoutAttention 이
# 의미 있는 이득을 내기 시작. baseline 128/128 과는 다른 체제.
# =============================================================================

HYBRID_TODO_NN=longctx_72b

# -----------------------------------------------------------------------------
# 모델
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-72B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.90            # long-context 는 KV 에 더 많이 할당
TENSOR_PARALLEL_SIZE=8
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS="--max-model-len 17000 --enable-prefix-caching"
                                # 17K context 지원, prefix cache 기본 on

# -----------------------------------------------------------------------------
# Workload — 8K input + 8K output
# -----------------------------------------------------------------------------
DATASET_NAME=random
NUM_PROMPTS=200                 # long-context 라 줄임 (처리시간 고려)
INPUT_LEN=8192
OUTPUT_LEN=8192
REQUEST_RATE=inf
MAX_CONCURRENCY=80              # HBM 포화 직전 상한 (KV 계산 기반)

# -----------------------------------------------------------------------------
# Hybrid — baseline 동일
# -----------------------------------------------------------------------------
HYBRID_CPU_MAX_SEQS=4
HYBRID_NUM_CPU_ENGINES=0
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=48
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

# -----------------------------------------------------------------------------
# 측정 infra
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=0
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100
VLLM_HYBRID_KERNEL_TRACE=0

# -----------------------------------------------------------------------------
# Ninja Gap Flags — 전부 off (pure baseline)
# -----------------------------------------------------------------------------
HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=900
SERVER_READY_POLL=5
