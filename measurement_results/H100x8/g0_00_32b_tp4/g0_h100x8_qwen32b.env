# =============================================================================
# G0 측정 template — H100x8 (Xeon 8480+ 2-socket SPR, Qwen2.5-7B)
# =============================================================================
#
# 저장 위치: measurement_results/H100x8/g0_${HYBRID_TODO_NN}/seqs${HYBRID_CPU_MAX_SEQS}/
#
# 사용법:
#   1) cp g0_h100x8_qwen7b.env /tmp/run.env
#   2) HYBRID_TODO_NN = 00 (baseline) 또는 05/06/... (기법 적용 후)
#   3) HYBRID_CPU_MAX_SEQS 설정 후 serve + bench (NinjaGap_Todo/01_G0_measurement.md 참조)
#
# =============================================================================

# -----------------------------------------------------------------------------
# 측정 라운드 식별
# -----------------------------------------------------------------------------
# TODO NN: 00=baseline, 03=§03, 04=§04, 05=§05, 06=§06, …
HYBRID_TODO_NN=00
HYBRID_CPU_MAX_SEQS=512

# -----------------------------------------------------------------------------
# 모델 / 워크로드 — H100x8 실측 기준 (TP=4, 8 GPU 중 4개만 active)
# -----------------------------------------------------------------------------
MODEL=Qwen/Qwen2.5-32B-Instruct
PORT=8000
GPU_MEMORY_UTIL=0.85
TENSOR_PARALLEL_SIZE=4
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
EXTRA_SERVE_ARGS=""

NUM_PROMPTS=500
INPUT_LEN=128
OUTPUT_LEN=128
REQUEST_RATE=inf

# -----------------------------------------------------------------------------
# Hybrid — 2 NUMA engine (H100x8 서버)
# -----------------------------------------------------------------------------
HYBRID_NUM_CPU_ENGINES=0           # auto = num_numa_nodes (= 2)
HYBRID_NUMA_AWARE=true
HYBRID_CPU_THREADS=0               # auto = NUMA phys cores (56)
HYBRID_CPU_CORE_RATIO=1.0
HYBRID_CPU_KVCACHE_GB=0
HYBRID_ROUTING_STRATEGY=capacity
HYBRID_ROUTING_PRIORITY=cpu-first
HYBRID_CPU_PREFILL_THRESHOLD=1024
HYBRID_WARMUP_REQUESTS=0
HYBRID_STATS_LOG_INTERVAL=50

# -----------------------------------------------------------------------------
# 측정 infra — 항상 ON
# -----------------------------------------------------------------------------
VLLM_HYBRID_TRACE=0
VLLM_HYBRID_TRACE_EVERY=0
VLLM_HYBRID_PROFILE=1
VLLM_HYBRID_PROFILE_SUBLAYER=1
VLLM_HYBRID_PROFILE_EVERY=100

# -----------------------------------------------------------------------------
# Ninja Gap 기법 Feature Flag
# -----------------------------------------------------------------------------
# Tier 0
HYBRID_HUGEPAGES=0
HYBRID_WOQ_INT8=0
HYBRID_KMP_BLOCKTIME=auto

# Tier 1 — hot path
HYBRID_VNNI_HOT_PATH=0
HYBRID_ISA_DISPATCH=auto
HYBRID_KERNEL_FUSION=0
HYBRID_LUT_SOFTMAX=0
HYBRID_LUT_SILU=0

# Tier 2 — batch scaling
HYBRID_HEAD_FOLDING=0
HYBRID_BATCH_AWARE_ATTN=off
HYBRID_PERSISTENT_OMP=0

# Tier 2 — big wins
HYBRID_TMAC_LUT_INT4=0
HYBRID_AVX_AMX_CASCADE=0
HYBRID_AMX_PREPACK=auto
HYBRID_SPARSE_BITMASK=0

# Tier 3 / 병행 / 장거리
HYBRID_CORE_GROUP_PIPELINE=0
HYBRID_SPEC_DECODE_CPU=0
HYBRID_PD_DISAGG=0
HYBRID_KV_OFFLOAD=0
HYBRID_SCOUT_ATTN=0
HYBRID_NEO_ASYMMETRIC=0

# -----------------------------------------------------------------------------
# Monitor / 결과
# -----------------------------------------------------------------------------
MONITOR_INTERVAL=1
RESULTS_DIR=results
SERVER_READY_TIMEOUT=600
SERVER_READY_POLL=5
